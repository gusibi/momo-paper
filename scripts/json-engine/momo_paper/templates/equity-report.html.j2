<!DOCTYPE html>
<html lang="{{ locale }}" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Momo Paper · Equity Report · {{ meta.title }}</title>
  <!-- META_INJECT -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      corePlugins: { preflight: false },
      theme: {
        extend: {
          colors: {
            surface0: 'var(--surface-0)',
            surface1: 'var(--surface-1)',
            surface2: 'var(--surface-2)',
            surface3: 'var(--surface-3)',
            brand: 'var(--brand)',
            paper: 'var(--paper)',
            ink: 'var(--ink)',
            subtle: 'var(--ink-subtle)',
            line: 'var(--line)',
          },
          fontFamily: {
            display: ['var(--font-display)'],
            body: ['var(--font-body)'],
            mono: ['var(--font-mono)'],
          },
        },
      },
    };
  </script>
  <style>
    /* ============================================================
       Momo Paper — Equity Report Design Tokens
       ============================================================ */

    /* ===== Light Theme (default) ===== */
    :root {
      --bg-primary: #f8f5ee;
      --bg-secondary: #f2efe6;
      --bg-tertiary: #ebe7dc;
      --bg-code: #f0ede4;
      --bg-elevated: #FAF8F4;
      --text-primary: #2d2a22;
      --text-secondary: #5c574a;
      --text-muted: #8c8676;
      --text-heading: #1a1812;
      --accent: #244C7A;
      --accent-hover: #1a3a5e;
      --accent-dim: #4A7DB5;
      --accent-glow: rgba(36, 76, 122, 0.08);
      --accent-2: #B65C3A;
      --accent-2-hover: #9a4d30;
      --accent-2-dim: #d4a853;
      --border: #d8d4c8;
      --border-light: #e8e4dc;
      --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.06);
      --shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
      --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.12);
      --green: #7b9e6d;
      --red: #c06a5a;
      --orange: #c98d4e;
      --blue: #7b8faa;
      --font-display: "Noto Serif SC", "Source Han Serif SC", "Songti SC", serif;
      --font-body: "Inter", "Noto Sans SC", "PingFang SC", sans-serif;
      --font-mono: "IBM Plex Mono", "SFMono-Regular", monospace;
      --space-xs: 0.25rem; --space-sm: 0.5rem; --space-md: 1rem;
      --space-lg: 1.5rem; --space-xl: 2rem; --space-2xl: 3rem;
      --space-3xl: 4rem;
      --radius-sm: 6px; --radius: 10px; --radius-lg: 16px;
      --max-width: 1100px; --max-width-text: 720px;
      --section-gap: 3.5rem;
      --canvas: var(--bg-secondary);
      --paper: var(--bg-elevated);
      --ink: var(--text-primary);
      --ink-subtle: var(--text-secondary);
      --line: var(--border);
      --brand: var(--accent);
      --brand-muted: var(--accent-glow);
      --font-sans: var(--font-body);
      --font-serif: var(--font-display);
      --success: var(--green);
      --danger: var(--red);
      --warning: var(--orange);
      --surface-0: var(--bg-primary);
      --surface-1: var(--bg-secondary);
      --surface-2: var(--bg-tertiary);
      --surface-3: var(--bg-elevated);
      --surface-card: #ffffff;
      --surface-card-hover: rgba(36, 76, 122, 0.04);
      --row-highlight-bg: rgba(36, 76, 122, 0.06);
      --header-bg: #1a2d3d;
      --header-text: #ffffff;
      --header-text-muted: rgba(255,255,255,0.65);
      --header-text-subtle: rgba(255,255,255,0.45);
      --header-accent: #5b9bd5;
      --header-card-bg: rgba(255,255,255,0.08);
      --header-card-border: rgba(255,255,255,0.12);
      --severity-high-bg: #fce4e4;
      --severity-medium-bg: #fef3e4;
      --severity-low-bg: #e4f5e4;
      --rating-buy-text: #7b9e6d;
      --rating-hold-text: #e0a85c;
      --rating-sell-text: #d4806e;
    }

    /* ===== Dark Theme ===== */
    [data-theme="dark"] {
      --bg-primary: #21211e;
      --bg-secondary: #2a2a27;
      --bg-tertiary: #33332f;
      --bg-code: #1c1c1a;
      --bg-elevated: #353532;
      --text-primary: #e6e2d8;
      --text-secondary: #b5b0a4;
      --text-muted: #7a766a;
      --text-heading: #f0ece2;
      --accent: #5C8DC2;
      --accent-hover: #6ea0d4;
      --accent-dim: #3a6090;
      --accent-glow: rgba(92, 141, 194, 0.1);
      --accent-2: #D4785A;
      --accent-2-hover: #e0886a;
      --accent-2-dim: #8a4a35;
      --border: #3a3832;
      --border-light: #2e2d28;
      --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.3);
      --shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
      --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.5);
      --green: #8aaf7a;
      --red: #d08070;
      --orange: #d9a060;
      --surface-card: var(--bg-elevated);
      --surface-card-hover: rgba(92, 141, 194, 0.08);
      --row-highlight-bg: rgba(92, 141, 194, 0.08);
      --header-bg: #141e2a;
      --header-card-bg: rgba(255,255,255,0.05);
      --header-card-border: rgba(255,255,255,0.08);
      --severity-high-bg: rgba(208, 128, 112, 0.15);
      --severity-medium-bg: rgba(217, 160, 96, 0.15);
      --severity-low-bg: rgba(138, 175, 122, 0.15);
      --rating-buy-text: #8aaf7a;
      --rating-hold-text: #d9a060;
      --rating-sell-text: #d08070;
    }

    /* ===== Reset & Base ===== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; text-size-adjust: 100%; }
    body {
      font-family: var(--font-body);
      font-size: 1.0625rem;
      line-height: 1.7;
      color: var(--text-primary);
      background: var(--bg-primary);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      transition: background-color 0.35s ease, color 0.35s ease;
    }
    ::selection { background: var(--accent-dim); color: #fff; }

    /* ===== Typography (element defaults) ===== */
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-display);
      font-weight: 600;
      line-height: 1.3;
      color: var(--text-heading);
    }
    p { margin-bottom: var(--space-lg); line-height: 1.75; }
    a { color: var(--accent); text-decoration: none; }
    a:hover { color: var(--accent-hover); }
    strong { font-weight: 600; color: var(--text-heading); }

    /* ===== Data table cell alignment (contextual, not a standalone class) ===== */
    .data-table thead th { text-align: right; }
    .data-table thead th:first-child { text-align: left; }
    .data-table tbody td { font-family: var(--font-mono); text-align: right; }
    .data-table tbody td:first-child { font-family: var(--font-sans); text-align: left; font-weight: 500; }

    /* ===== ER container default ul style ===== */
    .er-content ul:not([class]) { margin-left: 20px; line-height: 1.8; font-size: 14px; }

    /* ===== Print ===== */
    @media print {
      body { background: #fff; }
      .report-header { background: var(--header-bg); -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .theme-toggle { display: none !important; }
    }

    /* ===== Responsive ===== */
    @media (max-width: 768px) {
      .report-header { padding: 32px 0 28px; }
      .report-header h1 { font-size: 26px; }
      .risk-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
      .report-header h1 { font-size: 22px; }
    }
  </style>
</head>
<body>
  <!-- NAV_INJECT -->

  <button class="theme-toggle fixed right-6 top-5 z-[200] flex h-9 w-9 items-center justify-center rounded-full border border-line bg-[var(--surface-card)] text-base text-subtle transition-all duration-200 hover:border-brand hover:text-brand" id="themeToggle" aria-label="Toggle theme" title="Toggle theme">&#9788;</button>

  <!-- ============================================================
       REPORT HEADER — Full Width
       ============================================================ -->
  <div class="report-header w-full bg-[var(--header-bg)] px-0 py-12 text-[var(--header-text)] md:py-[48px_0_40px]">
    <div class="mx-auto max-w-[880px] px-6 md:px-6">
      <div class="mb-3 font-mono text-[11px] uppercase tracking-[0.08em] text-[var(--header-text-muted)]">{{ meta.eyebrow | default('Momo Paper · Equity Report') }}</div>
      <h1 class="font-sans !text-[36px] font-bold !leading-[1.2] !text-[var(--header-text)] !mb-1">{{ meta.title }}</h1>
      {% if meta.stock_full_name %}<div class="text-[15px] text-[var(--header-text-muted)] mb-1">{{ meta.stock_full_name }}</div>{% endif %}
      {% if meta.stock_code %}<div class="text-[13px] text-[var(--header-text-subtle)] mb-4">{{ meta.stock_code }}</div>{% endif %}
      <div class="mb-6 flex flex-wrap gap-4 font-sans text-[12px] text-[var(--header-text-muted)]">
        {% if meta.date %}<span class="whitespace-nowrap">{% if locale == 'zh-CN' %}报告日期：{% else %}Date: {% endif %}{{ meta.date }}</span>{% endif %}
        {% if meta.analyst %}<span class="whitespace-nowrap">{{ meta.analyst }}</span>{% endif %}
        {% if meta.industry %}<span class="whitespace-nowrap">{{ meta.industry }}</span>{% endif %}
        {% if sections.recommendation and sections.recommendation.rating %}
        <span class="whitespace-nowrap">
          {% if locale == 'zh-CN' %}评级：{% else %}Rating: {% endif %}
          <span class="inline-block rounded px-[10px] py-[2px] text-[11px] font-semibold uppercase tracking-[0.04em] {% if '买入' in sections.recommendation.rating or 'Buy' in sections.recommendation.rating %}bg-[rgba(123,158,109,0.25)] text-[var(--rating-buy-text)]{% elif '卖出' in sections.recommendation.rating or 'Sell' in sections.recommendation.rating %}bg-[rgba(192,106,90,0.25)] text-[var(--rating-sell-text)]{% else %}bg-[rgba(201,141,78,0.25)] text-[var(--rating-hold-text)]{% endif %}">{{ sections.recommendation.rating }}</span>
        </span>
        {% endif %}
      </div>

      {% if sections.kpis %}
      <div class="grid grid-cols-[repeat(auto-fit,minmax(140px,1fr))] gap-[10px] max-sm:grid-cols-2">
        {% for kpi in sections.kpis %}
        <div class="rounded-lg border border-[var(--header-card-border)] bg-[var(--header-card-bg)] px-4 py-[14px]">
          <div class="font-sans text-[11px] uppercase tracking-[0.04em] text-[var(--header-text-muted)] mb-1">{{ kpi.label }}</div>
          <div class="font-mono text-[24px] font-semibold leading-[1.1] text-[var(--header-text)]">{{ kpi.value }}</div>
          {% if kpi.sub %}<div class="mt-[2px] font-sans text-[11px] text-[var(--header-text-subtle)]">{{ kpi.sub }}</div>{% endif %}
        </div>
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </div>

  <!-- ============================================================
       MAIN CONTENT — Centered, constrained width
       ============================================================ -->
  <div class="er-content mx-auto max-w-[880px] px-6 md:px-6">

    {# ===== INVESTMENT THESIS ===== #}
    {% if sections.thesis %}
    <div class="my-8 rounded-[0_var(--radius)_var(--radius)_0] border-l-[4px] border-l-[var(--accent-2)] bg-[var(--canvas)] p-6">
      <div class="mb-2 font-sans text-[11px] font-semibold uppercase tracking-[0.06em] text-[var(--accent-2)]">{% if locale == 'zh-CN' %}投资结论{% else %}INVESTMENT THESIS{% endif %}</div>
      {% if sections.thesis.body %}
      <p class="text-[16px] leading-[1.6] text-ink mb-3">
        {{ sections.thesis.body }}
        {% if sections.thesis.rating %}
        <strong class="!text-brand">
          {% if locale == 'zh-CN' %}
            {% if '买入' in sections.thesis.rating or 'Buy' in sections.thesis.rating %}好公司，便宜价格——建议买入
            {% elif '持有' in sections.thesis.rating or 'Hold' in sections.thesis.rating %}好公司，不便宜——建议持有
            {% elif '卖出' in sections.thesis.rating or 'Sell' in sections.thesis.rating %}估值过高——建议规避
            {% else %}{{ sections.thesis.rating }}{% endif %}
          {% else %}{{ sections.thesis.rating }}{% endif %}
        </strong>
        {% endif %}
      </p>
      {% endif %}
      {% if sections.thesis.summary_points %}
      <ul class="mt-3 list-none pl-0">
        {% for pt in sections.thesis.summary_points %}
        <li class="relative mb-[6px] pl-5 text-[14px] leading-[1.6] text-ink before:absolute before:left-[4px] before:top-[9px] before:h-[6px] before:w-[6px] before:rounded-full before:bg-[var(--accent-2)] before:content-['']">{{ pt }}</li>
        {% endfor %}
      </ul>
      {% endif %}
    </div>
    {% endif %}

    {# ===== 1. BUSINESS SNAPSHOT ===== #}
    {% if sections.business_snapshot %}
    <section class="my-10">
      <h2 class="mb-5 border-b-2 border-brand pb-2 font-display text-[22px] font-bold !text-brand">{% if locale == 'zh-CN' %}一、公司概览{% else %}1. Business Snapshot{% endif %}</h2>
      {% for para in sections.business_snapshot.body %}
      <div class="my-3 text-[15px] leading-[1.75] text-ink [&_strong]:!text-brand">{{ para }}</div>
      {% endfor %}

      {% if sections.business_snapshot.financial_table %}
      <div class="my-5 overflow-x-auto">
        <table class="data-table w-full border-collapse text-[13px]">
          <thead>
            <tr>
              {% for h in sections.business_snapshot.financial_table.headers %}
              <th class="whitespace-nowrap border-b border-line bg-[var(--canvas)] px-3 py-[10px] font-sans text-[11px] font-semibold uppercase tracking-[0.04em] text-subtle">{{ h }}</th>
              {% endfor %}
            </tr>
          </thead>
          <tbody>
            {% for row in sections.business_snapshot.financial_table.rows %}
            <tr {% if row.highlight %}class="[&_td]:bg-[var(--row-highlight-bg)] [&_td]:font-semibold"{% endif %}>
              {% for cell in row.data %}
              <td class="whitespace-nowrap border-b border-line px-3 py-2 text-[12px]">{{ cell }}</td>
              {% endfor %}
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% endif %}

      {% if sections.business_snapshot.revenue_chart %}
      <div class="my-5 rounded-lg border border-line bg-[var(--surface-card)] p-5">
        {% if sections.business_snapshot.revenue_chart.title %}<div class="mb-1 font-sans text-[13px] font-semibold text-ink">{{ sections.business_snapshot.revenue_chart.title }}</div>{% endif %}
        {% if sections.business_snapshot.revenue_chart.note %}<div class="mb-3 font-sans text-[11px] text-subtle">{{ sections.business_snapshot.revenue_chart.note }}</div>{% endif %}
        <div class="[&_svg]:block [&_svg]:h-auto [&_svg]:w-full">{{ sections.business_snapshot.revenue_chart | render_chart }}</div>
      </div>
      {% endif %}

      {% if sections.business_snapshot.roe_chart %}
      <div class="my-5 rounded-lg border border-line bg-[var(--surface-card)] p-5">
        {% if sections.business_snapshot.roe_chart.title %}<div class="mb-1 font-sans text-[13px] font-semibold text-ink">{{ sections.business_snapshot.roe_chart.title }}</div>{% endif %}
        {% if sections.business_snapshot.roe_chart.note %}<div class="mb-3 font-sans text-[11px] text-subtle">{{ sections.business_snapshot.roe_chart.note }}</div>{% endif %}
        <div class="[&_svg]:block [&_svg]:h-auto [&_svg]:w-full">{{ sections.business_snapshot.roe_chart | render_chart }}</div>
      </div>
      {% endif %}

      {% if sections.business_snapshot.moat %}
      <div class="my-4 rounded-lg bg-[var(--brand-muted)] p-5">
        <div class="mb-[6px] font-sans text-[11px] font-semibold uppercase tracking-[0.04em] text-brand">{% if locale == 'zh-CN' %}护城河评估{% else %}Moat Assessment{% endif %}</div>
        <p class="text-[14px] leading-[1.6] text-ink !mb-0">{{ sections.business_snapshot.moat }}</p>
      </div>
      {% endif %}
    </section>
    {% endif %}

    {# ===== 2. PRICE & DRIVERS ===== #}
    {% if sections.price_and_drivers %}
    <section class="my-10">
      <h2 class="mb-5 border-b-2 border-brand pb-2 font-display text-[22px] font-bold !text-brand">{% if locale == 'zh-CN' %}二、股价走势{% else %}2. Price & Drivers{% endif %}</h2>
      {% for para in sections.price_and_drivers.body %}
      <div class="my-3 text-[15px] leading-[1.75] text-ink [&_strong]:!text-brand">{{ para }}</div>
      {% endfor %}

      {% if sections.price_and_drivers.price_chart %}
      <div class="my-5 rounded-lg border border-line bg-[var(--surface-card)] p-5">
        {% if sections.price_and_drivers.price_chart.title %}<div class="mb-1 font-sans text-[13px] font-semibold text-ink">{{ sections.price_and_drivers.price_chart.title }}</div>{% endif %}
        {% if sections.price_and_drivers.price_chart.note %}<div class="mb-3 font-sans text-[11px] text-subtle">{{ sections.price_and_drivers.price_chart.note }}</div>{% endif %}
        <div class="[&_svg]:block [&_svg]:h-auto [&_svg]:w-full">{{ sections.price_and_drivers.price_chart | render_chart }}</div>
      </div>
      {% endif %}

      {% if sections.price_and_drivers.price_nodes %}
      <ul class="relative my-5 list-none pl-[28px] before:absolute before:bottom-1 before:left-[7px] before:top-1 before:w-[2px] before:bg-line before:content-['']">
        {% for node in sections.price_and_drivers.price_nodes %}
        <li class="relative mb-4 pl-8 last:mb-0 before:absolute before:left-[-24px] before:top-[6px] before:z-[1] before:h-[12px] before:w-[12px] before:rounded-full before:border-2 before:border-[var(--bg-primary)] before:bg-brand before:content-['']">
          <div class="mb-[2px] font-mono text-[12px] text-brand">{{ node.date }} <span class="font-semibold text-ink">{{ node.price }}</span></div>
          <div class="text-[13px] leading-[1.5] text-subtle">{{ node.description }}</div>
        </li>
        {% endfor %}
      </ul>
      {% endif %}

      {% if sections.price_and_drivers.eps_chart %}
      <div class="my-5 rounded-lg border border-line bg-[var(--surface-card)] p-5">
        {% if sections.price_and_drivers.eps_chart.title %}<div class="mb-1 font-sans text-[13px] font-semibold text-ink">{{ sections.price_and_drivers.eps_chart.title }}</div>{% endif %}
        {% if sections.price_and_drivers.eps_chart.note %}<div class="mb-3 font-sans text-[11px] text-subtle">{{ sections.price_and_drivers.eps_chart.note }}</div>{% endif %}
        <div class="[&_svg]:block [&_svg]:h-auto [&_svg]:w-full">{{ sections.price_and_drivers.eps_chart | render_chart }}</div>
      </div>
      {% endif %}

      {% if sections.price_and_drivers.drivers %}
      <div class="my-4 rounded-lg bg-[var(--brand-muted)] p-5">
        <div class="mb-[6px] font-sans text-[11px] font-semibold uppercase tracking-[0.04em] text-brand">{% if locale == 'zh-CN' %}核心驱动因素{% else %}Key Drivers{% endif %}</div>
        {% for driver in sections.price_and_drivers.drivers %}
        <p class="!mb-1 text-[14px] leading-[1.6] text-ink"><strong>{{ driver }}</strong></p>
        {% endfor %}
      </div>
      {% endif %}
    </section>
    {% endif %}

    {# ===== 3. VALUATION ===== #}
    {% if sections.valuation %}
    <section class="my-10">
      <h2 class="mb-5 border-b-2 border-brand pb-2 font-display text-[22px] font-bold !text-brand">{% if locale == 'zh-CN' %}三、估值分析{% else %}3. Valuation{% endif %}</h2>
      {% for para in sections.valuation.body %}
      <div class="my-3 text-[15px] leading-[1.75] text-ink [&_strong]:!text-brand">{{ para }}</div>
      {% endfor %}

      {% if sections.valuation.metrics_table %}
      <table class="val-metrics-table my-5 w-full border-collapse text-[13px]">
        <thead>
          <tr>
            {% for h in sections.valuation.metrics_table.headers %}
            <th class="border-b border-line bg-[var(--canvas)] px-3 py-[10px] text-left font-sans text-[11px] font-semibold uppercase tracking-[0.04em] text-subtle">{{ h }}</th>
            {% endfor %}
          </tr>
        </thead>
        <tbody>
          {% for row in sections.valuation.metrics_table.rows %}
          <tr>
            <td class="border-b border-line px-3 py-[10px] text-[13px]">{{ row.indicator }}</td>
            <td class="border-b border-line px-3 py-[10px] text-[13px]">{{ row.value }}</td>
            <td class="border-b border-line px-3 py-[10px] text-[13px] {% if row.eval_class == 'eval-positive' %}font-semibold text-[var(--success)]{% elif row.eval_class == 'eval-negative' %}font-semibold text-[var(--danger)]{% elif row.eval_class == 'eval-neutral' %}text-[var(--warning)]{% endif %}">{{ row.evaluation }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% endif %}

      {% if sections.valuation.chart %}
      <div class="my-5 rounded-lg border border-line bg-[var(--surface-card)] p-5">
        {% if sections.valuation.chart.title %}<div class="mb-1 font-sans text-[13px] font-semibold text-ink">{{ sections.valuation.chart.title }}</div>{% endif %}
        {% if sections.valuation.chart.note %}<div class="mb-3 font-sans text-[11px] text-subtle">{{ sections.valuation.chart.note }}</div>{% endif %}
        <div class="[&_svg]:block [&_svg]:h-auto [&_svg]:w-full">{{ sections.valuation.chart | render_chart }}</div>
      </div>
      {% endif %}

      {% if sections.valuation.table %}
      <div class="my-5 overflow-x-auto">
        <table class="data-table w-full border-collapse text-[13px]">
          <thead>
            <tr>
              {% for h in sections.valuation.table.headers %}
              <th class="whitespace-nowrap border-b border-line bg-[var(--canvas)] px-3 py-[10px] font-sans text-[11px] font-semibold uppercase tracking-[0.04em] text-subtle">{{ h }}</th>
              {% endfor %}
            </tr>
          </thead>
          <tbody>
            {% for row in sections.valuation.table.rows %}
            <tr {% if row.highlight %}class="[&_td]:bg-[var(--row-highlight-bg)] [&_td]:font-semibold"{% endif %}>
              {% for cell in row.data %}
              <td class="whitespace-nowrap border-b border-line px-3 py-2 text-[12px]">{{ cell }}</td>
              {% endfor %}
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% endif %}

      {% if sections.valuation.fair_value %}
      <div class="my-5 grid grid-cols-[repeat(auto-fit,minmax(200px,1fr))] gap-4 rounded-lg border border-line bg-[var(--surface-card)] p-5 max-md:grid-cols-1">
        {% for item in sections.valuation.fair_value %}
        <div class="text-center">
          <div class="mb-1 font-sans text-[11px] uppercase tracking-[0.04em] text-subtle">{{ item.label }}</div>
          <div class="font-mono text-[18px] font-semibold text-brand">{{ item.value }}</div>
          {% if item.note %}<div class="mt-[2px] font-sans text-[11px] text-subtle">{{ item.note }}</div>{% endif %}
        </div>
        {% endfor %}
      </div>
      {% endif %}

      {% if sections.valuation.insight %}
      <div class="my-4 rounded-lg bg-[var(--brand-muted)] p-5">
        <div class="mb-[6px] font-sans text-[11px] font-semibold uppercase tracking-[0.04em] text-brand">{% if locale == 'zh-CN' %}估值判断{% else %}Valuation Insight{% endif %}</div>
        <p class="!mb-0 text-[14px] leading-[1.6] text-ink">{{ sections.valuation.insight }}</p>
      </div>
      {% endif %}
    </section>
    {% endif %}

    {# ===== 4. RISKS & CATALYSTS ===== #}
    {% if sections.risks_and_catalysts %}
    <section class="my-10">
      <h2 class="mb-5 border-b-2 border-brand pb-2 font-display text-[22px] font-bold !text-brand">{% if locale == 'zh-CN' %}四、风险与催化剂{% else %}4. Risks & Catalysts{% endif %}</h2>

      {% if sections.risks_and_catalysts.risks %}
      <div class="risk-grid grid grid-cols-2 gap-4 my-4 max-md:grid-cols-1">
        {% for risk in sections.risks_and_catalysts.risks %}
        <div class="rounded-lg border border-line bg-[var(--surface-card)] p-4">
          <span class="mb-2 inline-block rounded px-2 py-[2px] font-mono text-[10px] font-semibold uppercase tracking-[0.06em] {% if risk.severity == 'high' %}bg-[var(--severity-high-bg)] text-[var(--danger)]{% elif risk.severity == 'medium' %}bg-[var(--severity-medium-bg)] text-[var(--warning)]{% else %}bg-[var(--severity-low-bg)] text-[var(--success)]{% endif %}">
            {% if locale == 'zh-CN' %}
              {% if risk.severity == 'high' %}高风险{% elif risk.severity == 'medium' %}中风险{% else %}低风险{% endif %}
            {% else %}{{ risk.severity | upper }}{% endif %}
          </span>
          <div class="mb-1 font-display text-[14px] font-semibold text-ink">{{ risk.title }}</div>
          {% if risk.description %}<p class="!mb-0 text-[13px] leading-[1.6] text-subtle">{{ risk.description }}</p>{% endif %}
        </div>
        {% endfor %}
      </div>
      {% endif %}

      {% if sections.risks_and_catalysts.catalysts %}
      <div class="my-4 rounded-lg bg-[var(--brand-muted)] p-5">
        <div class="mb-[6px] font-sans text-[11px] font-semibold uppercase tracking-[0.04em] text-brand">{% if locale == 'zh-CN' %}近期催化剂{% else %}Upcoming Catalysts{% endif %}</div>
        <ul class="mt-3 list-none pl-0">
          {% for cat in sections.risks_and_catalysts.catalysts %}
          <li class="border-b border-line py-2 text-[14px] leading-[1.5] last:border-b-0">
            <div>
              <span class="font-semibold text-ink">{{ cat.title }}</span>
              {% if cat.timeline %}<span class="ml-2 font-mono text-[11px] text-brand">{{ cat.timeline }}</span>{% endif %}
            </div>
            {% if cat.description %}<div class="mt-[2px] text-[13px] text-subtle">{{ cat.description }}</div>{% endif %}
          </li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
    </section>
    {% endif %}

    {# ===== 5. INVESTMENT RECOMMENDATION ===== #}
    {% if sections.recommendation %}
    <section class="my-10">
      <h2 class="mb-5 border-b-2 border-brand pb-2 font-display text-[22px] font-bold !text-brand">{% if locale == 'zh-CN' %}五、投资建议{% else %}5. Investment Recommendation{% endif %}</h2>

      <div class="my-6 rounded-lg bg-brand p-7 text-white">
        <h3 class="mb-3 text-[20px] font-bold !text-white">
          {% if locale == 'zh-CN' %}
            {% if sections.recommendation.rating %}{{ sections.recommendation.rating }}{% else %}投资评级{% endif %}
            {% if sections.recommendation.summary %} — {{ sections.recommendation.summary }}{% endif %}
          {% else %}
            {% if sections.recommendation.rating %}{{ sections.recommendation.rating }}{% else %}INVESTMENT RATING{% endif %}
            {% if sections.recommendation.summary %} — {{ sections.recommendation.summary }}{% endif %}
          {% endif %}
        </h3>
        <p class="!mb-4 text-[14px] leading-[1.6] text-white/[0.85]">{{ sections.recommendation.body }}</p>
        {% if sections.recommendation.rating or sections.recommendation.target_price %}
        <div class="mt-4 flex gap-5 flex-wrap max-md:flex-col max-md:gap-3">
          {% if sections.recommendation.rating %}
          <div class="min-w-[140px] flex-1">
            <div class="mb-[2px] font-sans text-[11px] uppercase tracking-[0.04em] text-white/50">{% if locale == 'zh-CN' %}评级{% else %}Rating{% endif %}</div>
            <div class="text-[18px] font-semibold text-white">{{ sections.recommendation.rating }}</div>
          </div>
          {% endif %}
          {% if sections.recommendation.target_price %}
          <div class="min-w-[140px] flex-1">
            <div class="mb-[2px] font-sans text-[11px] uppercase tracking-[0.04em] text-white/50">{% if locale == 'zh-CN' %}目标价{% else %}Target Price{% endif %}</div>
            <div class="text-[18px] font-semibold text-white">{{ sections.recommendation.target_price }}</div>
          </div>
          {% endif %}
          {% if sections.recommendation.horizon %}
          <div class="min-w-[140px] flex-1">
            <div class="mb-[2px] font-sans text-[11px] uppercase tracking-[0.04em] text-white/50">{% if locale == 'zh-CN' %}投资周期{% else %}Horizon{% endif %}</div>
            <div class="text-[18px] font-semibold text-white">{{ sections.recommendation.horizon }}</div>
          </div>
          {% endif %}
        </div>
        {% endif %}
      </div>

      {% if sections.recommendation.cards %}
      <div class="my-5 grid grid-cols-3 gap-4 max-md:grid-cols-1">
        {% for card in sections.recommendation.cards %}
        <div class="rounded-lg border border-line bg-[var(--surface-card)] p-5 text-center">
          {% if card.icon %}<div class="mb-2 text-[28px]">{{ card.icon }}</div>{% endif %}
          <h4 class="mb-2 font-display text-[15px] font-semibold text-ink">{{ card.title }}</h4>
          <p class="!mb-0 text-[13px] leading-[1.6] text-subtle">{{ card.body }}</p>
        </div>
        {% endfor %}
      </div>
      {% endif %}
    </section>
    {% endif %}

    {# ===== FOOTER ===== #}
    <div class="mt-12 border-t border-line py-6 font-sans text-[11px] leading-[1.6] text-subtle">
      <p class="!mb-0"><strong class="!text-ink">{% if locale == 'zh-CN' %}免责声明：{% else %}Disclaimer:{% endif %}</strong>
      {{ meta.disclaimer | default('本报告仅供参考，不构成投资建议。投资有风险，入市需谨慎。') }}</p>
      {% if meta.source %}<p class="!mb-0"><strong class="!text-ink">{% if locale == 'zh-CN' %}数据来源：{% else %}Source:{% endif %}</strong>
      {{ meta.source }}</p>{% endif %}
      {% if meta.date %}<p class="!mb-0"><strong class="!text-ink">{% if locale == 'zh-CN' %}报告生成时间：{% else %}Generated:{% endif %}</strong>
      {{ meta.date }}{% if meta.analyst %} · {{ meta.analyst }}{% endif %}{% if meta.brand %} · {{ meta.brand }}{% endif %}</p>{% endif %}
    </div>

  </div>

  <!-- FOOTER_INJECT -->

  <script>
    (function() {
      const KEY = 'momo-theme';
      const toggle = document.getElementById('themeToggle');
      const html = document.documentElement;

      function setIcon(theme) { toggle.innerHTML = theme === 'light' ? '&#9790;' : '&#9788;'; }

      const stored = localStorage.getItem(KEY);
      if (stored) html.setAttribute('data-theme', stored);
      setIcon(html.getAttribute('data-theme'));

      toggle.addEventListener('click', function() {
        const next = html.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
        html.setAttribute('data-theme', next);
        localStorage.setItem(KEY, next);
        setIcon(next);
      });
    })();
  </script>
</body>
</html>
