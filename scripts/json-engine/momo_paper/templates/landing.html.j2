<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ meta.title }}</title>
  <!-- META_INJECT -->
  <style>
    /* ===== Design Tokens ===== */
    :root {
      --ink: #172033;
      --ink-subtle: #4C566A;
      --paper: #FAF8F4;
      --canvas: #F2EFE8;
      --line: #D8D2C4;
      --brand: #244C7A;
      --brand-muted: #DCE7F2;
      --accent: #B65C3A;
      --accent-muted: #F2E1D9;
      --success: #2F6B4F;
      --success-muted: #D9F2E5;
      --warning: #A46A21;
      --danger: #9A3D3D;
      --font-serif: "Noto Serif SC", "Source Han Serif SC", "Songti SC", serif;
      --font-sans: "Inter", "Noto Sans SC", "PingFang SC", sans-serif;
      --font-mono: "IBM Plex Mono", "SFMono-Regular", monospace;
      --radius-sm: 6px;
      --radius-md: 10px;
      --radius-lg: 16px;
      --shadow-card: 0 1px 3px rgba(23,32,51,0.06), 0 4px 12px rgba(23,32,51,0.04);
      --shadow-raised: 0 4px 8px rgba(23,32,51,0.06), 0 12px 28px rgba(23,32,51,0.08);
      --ease: cubic-bezier(0.22, 0.61, 0.36, 1);
      --content-width: 1152px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font-sans);
      font-size: 15px;
      line-height: 1.6;
      color: var(--ink);
      background: var(--paper);
      -webkit-font-smoothing: antialiased;
    }

    /* ===== Section Shared ===== */
    .section-label {
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--brand);
      display: block;
      margin-bottom: 16px;
    }
    .section-title {
      font-family: var(--font-serif);
      font-size: 32px;
      font-weight: 600;
      color: var(--ink);
      margin-bottom: 16px;
    }
    .section-subtitle {
      font-size: 16px;
      color: var(--ink-subtle);
      max-width: 600px;
      margin-bottom: 48px;
      line-height: 1.55;
    }

    /* ===== Hero ===== */
    .hero {
      padding: 100px 48px 80px;
      text-align: center;
      background: linear-gradient(180deg, var(--canvas) 0%, var(--paper) 100%);
      border-bottom: 1px solid var(--line);
    }
    .hero-badge {
      display: inline-block;
      padding: 6px 16px;
      background: var(--brand-muted);
      color: var(--brand);
      border-radius: 20px;
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.03em;
      margin-bottom: 32px;
    }
    .hero h1 {
      font-family: var(--font-serif);
      font-size: 52px;
      font-weight: 600;
      line-height: 1.15;
      color: var(--ink);
      max-width: 800px;
      margin: 0 auto 24px;
      letter-spacing: -0.01em;
    }
    .hero .subtitle {
      font-size: 18px;
      line-height: 1.6;
      color: var(--ink-subtle);
      max-width: 620px;
      margin: 0 auto 40px;
    }
    .hero-actions {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      padding: 13px 28px;
      background: var(--brand);
      color: #fff;
      font-family: var(--font-sans);
      font-size: 15px;
      font-weight: 500;
      border-radius: var(--radius-sm);
      text-decoration: none;
      transition: background 0.15s ease, transform 0.15s ease;
    }
    .btn-primary:hover { background: #1a3a5e; transform: translateY(-1px); }
    .btn-outline {
      display: inline-flex;
      align-items: center;
      padding: 13px 28px;
      background: transparent;
      color: var(--brand);
      font-family: var(--font-sans);
      font-size: 15px;
      font-weight: 500;
      border: 1.5px solid var(--brand);
      border-radius: var(--radius-sm);
      text-decoration: none;
      transition: background 0.15s ease, transform 0.15s ease;
    }
    .btn-outline:hover { background: var(--brand-muted); transform: translateY(-1px); }

    /* ===== Hero Pipeline ===== */
    .hero-pipeline {
      margin-top: 56px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      flex-wrap: wrap;
    }
    .pipeline-node {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      padding: 20px 32px;
      text-align: center;
      transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
      min-width: 140px;
    }
    .pipeline-node:hover {
      border-color: var(--brand);
      transform: translateY(-2px);
      box-shadow: var(--shadow-raised);
    }
    .pipeline-node__label {
      font-family: var(--font-mono);
      font-size: 15px;
      font-weight: 600;
      color: var(--brand);
      margin-bottom: 4px;
    }
    .pipeline-node__desc {
      font-family: var(--font-sans);
      font-size: 12px;
      color: var(--ink-subtle);
    }
    .pipeline-arrow {
      font-family: var(--font-mono);
      font-size: 22px;
      color: var(--line);
      flex-shrink: 0;
    }

    /* ===== Features ===== */
    .features {
      max-width: var(--content-width);
      margin: 0 auto;
      padding: 88px 48px;
    }
    .features-header {
      text-align: center;
      margin-bottom: 56px;
    }
    .feature-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .feature-card {
      padding: 36px 32px;
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    }
    .feature-card:hover {
      border-color: var(--brand-muted);
      box-shadow: var(--shadow-raised);
      transform: translateY(-2px);
    }
    .feature-icon {
      width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--radius-sm);
      font-size: 20px;
      margin-bottom: 20px;
    }
    .feature-icon.docs     { background: var(--brand-muted); color: var(--brand); }
    .feature-icon.charts   { background: var(--accent-muted); color: var(--accent); }
    .feature-icon.diagrams { background: var(--success-muted); color: var(--success); }
    .feature-icon.templates { background: #F0EBD9; color: var(--warning); }
    .feature-icon.mcp      { background: #E5DFF2; color: #5E3D8A; }
    .feature-icon.print    { background: #D9E8F2; color: #3D6D8A; }
    .feature-card h3 {
      font-family: var(--font-serif);
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 10px;
      color: var(--ink);
    }
    .feature-card p {
      font-size: 14px;
      color: var(--ink-subtle);
      line-height: 1.55;
    }

    /* ===== Workflows ===== */
    .workflows {
      max-width: var(--content-width);
      margin: 0 auto;
      padding: 0 48px 88px;
    }
    .workflows-header {
      text-align: center;
      margin-bottom: 56px;
    }
    .workflow-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .workflow-card {
      padding: 40px 32px;
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      position: relative;
      transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    }
    .workflow-card:hover {
      border-color: var(--brand-muted);
      box-shadow: var(--shadow-raised);
      transform: translateY(-2px);
    }
    .workflow-card__num {
      font-family: var(--font-serif);
      font-size: 36px;
      font-weight: 600;
      color: var(--line);
      margin-bottom: 20px;
      line-height: 1;
    }
    .workflow-card__tag {
      display: inline-block;
      padding: 3px 10px;
      background: var(--brand-muted);
      color: var(--brand);
      border-radius: 12px;
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.03em;
      margin-bottom: 16px;
    }
    .workflow-card h3 {
      font-family: var(--font-serif);
      font-size: 20px;
      font-weight: 600;
      margin-bottom: 6px;
      color: var(--ink);
    }
    .workflow-card__subtitle {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--ink-subtle);
      letter-spacing: 0.02em;
      margin-bottom: 16px;
    }
    .workflow-card__desc {
      font-size: 14px;
      color: var(--ink-subtle);
      line-height: 1.55;
      margin-bottom: 20px;
    }
    .workflow-card__highlights {
      list-style: none;
      padding: 0;
      border-top: 1px solid var(--line);
      padding-top: 16px;
    }
    .workflow-card__highlights li {
      font-size: 13px;
      color: var(--ink-subtle);
      padding: 4px 0;
      padding-left: 20px;
      position: relative;
    }
    .workflow-card__highlights li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 11px;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--brand);
      opacity: 0.5;
    }

    /* ===== Document Types Grid ===== */
    .doc-types {
      padding: 88px 48px;
      background: var(--canvas);
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }
    .doc-types-inner {
      max-width: var(--content-width);
      margin: 0 auto;
    }
    .doc-types-header {
      text-align: center;
      margin-bottom: 56px;
    }
    .doc-type-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 12px;
    }
    .doc-type-card {
      padding: 20px 16px;
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      text-align: center;
      transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
      text-decoration: none;
    }
    .doc-type-card:hover {
      border-color: var(--brand);
      transform: translateY(-2px);
      box-shadow: var(--shadow-card);
    }
    .doc-type-card__icon {
      width: 36px;
      height: 36px;
      margin: 0 auto 10px;
      background: var(--brand-muted);
      color: var(--brand);
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-serif);
      font-size: 16px;
      font-weight: 600;
    }
    .doc-type-card__name {
      font-family: var(--font-sans);
      font-size: 13px;
      font-weight: 500;
      color: var(--ink);
      margin-bottom: 4px;
    }
    .doc-type-card__slug {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--ink-subtle);
      margin-bottom: 6px;
    }
    .doc-type-card__desc {
      font-size: 11px;
      color: var(--ink-subtle);
      line-height: 1.4;
    }

    /* ===== Comparison ===== */
    .comparison {
      max-width: var(--content-width);
      margin: 0 auto;
      padding: 88px 48px;
    }
    .comparison-header {
      text-align: center;
      margin-bottom: 56px;
    }
    .compare-grid {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 32px;
      align-items: start;
    }
    .compare-card {
      padding: 40px 36px;
      border-radius: var(--radius-lg);
    }
    .compare-card--old {
      background: var(--paper);
      border: 1px solid var(--line);
    }
    .compare-card--new {
      background: var(--paper);
      border: 2px solid var(--brand);
      box-shadow: 0 0 0 8px var(--brand-muted);
    }
    .compare-card__label {
      font-family: var(--font-mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 16px;
      display: block;
    }
    .compare-card--old .compare-card__label { color: var(--ink-subtle); }
    .compare-card--new .compare-card__label { color: var(--brand); font-weight: 600; }
    .compare-card h3 {
      font-family: var(--font-serif);
      font-size: 24px;
      font-weight: 600;
      margin-bottom: 8px;
      color: var(--ink);
    }
    .compare-card__subtitle {
      font-size: 14px;
      color: var(--ink-subtle);
      margin-bottom: 24px;
    }
    .compare-card__list {
      list-style: none;
      padding: 0;
    }
    .compare-card__list li {
      padding: 8px 0;
      padding-left: 28px;
      position: relative;
      font-size: 14px;
      color: var(--ink-subtle);
      line-height: 1.5;
    }
    .compare-card--old .compare-card__list li::before {
      content: '\2717';
      position: absolute;
      left: 0;
      color: var(--danger);
      font-size: 13px;
      font-weight: 700;
    }
    .compare-card--new .compare-card__list li::before {
      content: '\2713';
      position: absolute;
      left: 0;
      color: var(--success);
      font-size: 13px;
      font-weight: 700;
    }
    .compare-divider {
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-mono);
      font-size: 18px;
      color: var(--line);
      font-weight: 600;
      padding: 24px 0;
      white-space: nowrap;
    }

    /* ===== Numbers Strip ===== */
    .numbers-strip {
      max-width: var(--content-width);
      margin: 0 auto;
      padding: 0 48px 88px;
    }
    .numbers-inner {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
      padding: 44px 48px;
      background: var(--canvas);
      border-radius: var(--radius-lg);
      border: 1px solid var(--line);
      text-align: center;
    }
    .num-value {
      font-family: var(--font-serif);
      font-size: 40px;
      font-weight: 600;
      color: var(--brand);
      line-height: 1.1;
      margin-bottom: 6px;
    }
    .num-label {
      font-size: 13px;
      color: var(--ink-subtle);
      font-family: var(--font-mono);
      letter-spacing: 0.03em;
    }

    /* ===== Ecosystem ===== */
    .ecosystem {
      max-width: var(--content-width);
      margin: 0 auto;
      padding: 0 48px 88px;
    }
    .ecosystem-header {
      text-align: center;
      margin-bottom: 56px;
    }
    .ecosystem-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;
    }
    .ecosystem-card {
      padding: 24px 18px;
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      text-align: center;
      text-decoration: none;
      transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    }
    .ecosystem-card:hover {
      border-color: var(--brand);
      transform: translateY(-2px);
      box-shadow: var(--shadow-card);
    }
    .ecosystem-card__name {
      font-family: var(--font-serif);
      font-size: 16px;
      font-weight: 600;
      color: var(--ink);
      margin-bottom: 6px;
    }
    .ecosystem-card__desc {
      font-size: 12px;
      color: var(--ink-subtle);
      line-height: 1.4;
    }

    /* ===== Bottom CTA ===== */
    .bottom-cta {
      max-width: var(--content-width);
      margin: 0 auto;
      padding: 0 48px 100px;
    }
    .cta-inner {
      text-align: center;
      padding: 64px 48px;
      background: linear-gradient(135deg, var(--brand) 0%, #1a3a5e 100%);
      border-radius: var(--radius-lg);
      color: #fff;
    }
    .cta-inner h2 {
      font-family: var(--font-serif);
      font-size: 32px;
      font-weight: 600;
      margin-bottom: 14px;
    }
    .cta-inner p {
      font-size: 16px;
      opacity: 0.85;
      max-width: 500px;
      margin: 0 auto 32px;
      line-height: 1.55;
    }
    .cta-inner .btn-primary {
      background: #fff;
      color: var(--brand);
      font-weight: 600;
    }
    .cta-inner .btn-primary:hover { background: var(--brand-muted); }

    /* ===== Responsive ===== */
    @media (max-width: 1024px) {
      .doc-type-grid { grid-template-columns: repeat(3, 1fr); }
      .ecosystem-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 860px) {
      .hero { padding: 64px 24px 56px; }
      .hero h1 { font-size: 36px; }
      .hero .subtitle { font-size: 16px; }
      .feature-grid { grid-template-columns: 1fr; }
      .workflow-grid { grid-template-columns: 1fr; }
      .compare-grid { grid-template-columns: 1fr; }
      .compare-divider { transform: rotate(90deg); padding: 8px 0; }
      .numbers-inner { grid-template-columns: repeat(2, 1fr); row-gap: 32px; }
      .features { padding: 56px 24px; }
      .workflows { padding: 0 24px 56px; }
      .doc-types { padding: 56px 24px; }
      .comparison { padding: 56px 24px; }
      .ecosystem { padding: 0 24px 56px; }
      .bottom-cta { padding: 0 24px 72px; }
      .cta-inner { padding: 44px 28px; }
      .section-title { font-size: 28px; }
    }
    @media (max-width: 600px) {
      .doc-type-grid { grid-template-columns: repeat(2, 1fr); }
      .ecosystem-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 500px) {
      .hero h1 { font-size: 28px; }
      .numbers-inner { grid-template-columns: 1fr; }
      .hero-actions { flex-direction: column; align-items: center; }
      .hero-pipeline { flex-direction: column; gap: 8px; }
      .pipeline-arrow { transform: rotate(90deg); }
      .doc-type-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
<body>
  {# ===== Hero ===== #}
  <section class="hero">
    {% if sections.hero.badge %}<div class="hero-badge">{{ sections.hero.badge }}</div>{% endif %}
    <h1>{{ sections.hero.headline }}</h1>
    <p class="subtitle">{{ sections.hero.description }}</p>
    <div class="hero-actions">
      {% for btn in sections.hero.cta_buttons %}
      <a href="{{ btn.url }}" class="{{ btn.style | default('btn-primary') }}">{{ btn.label }}</a>
      {% endfor %}
    </div>

    {% if sections.hero.pipeline %}
    <div class="hero-pipeline">
      {% for item in sections.hero.pipeline %}
      {% if not loop.first %}<span class="pipeline-arrow">&rarr;</span>{% endif %}
      <div class="pipeline-node">
        <div class="pipeline-node__label">{{ item.label }}</div>
        <div class="pipeline-node__desc">{{ item.desc }}</div>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </section>

  {# ===== Features ===== #}
  <section class="features">
    <div class="features-header">
      {% if sections.features.label %}<span class="section-label">{{ sections.features.label }}</span>{% endif %}
      <h2 class="section-title">{{ sections.features.heading }}</h2>
      <p class="section-subtitle" style="margin-left:auto;margin-right:auto;">{{ sections.features.description }}</p>
    </div>
    <div class="feature-grid">
      {% for feat in sections.features.cards %}
      <div class="feature-card">
        <div class="feature-icon {{ feat.icon_class }}">{{ feat.icon }}</div>
        <h3>{{ feat.title }}</h3>
        <p>{{ feat.description }}</p>
      </div>
      {% endfor %}
    </div>
  </section>

  {# ===== Workflows ===== #}
  {% if sections.workflows %}
  <section class="workflows">
    <div class="workflows-header">
      <span class="section-label">{{ sections.workflows.label }}</span>
      <h2 class="section-title">{{ sections.workflows.heading }}</h2>
      <p class="section-subtitle" style="margin-left:auto;margin-right:auto;">{{ sections.workflows.description }}</p>
    </div>
    <div class="workflow-grid">
      {% for path in sections.workflows.paths %}
      <div class="workflow-card">
        <div class="workflow-card__num">{{ path.num }}</div>
        {% if path.tag %}<span class="workflow-card__tag">{{ path.tag }}</span>{% endif %}
        <h3>{{ path.title }}</h3>
        <p class="workflow-card__subtitle">{{ path.subtitle }}</p>
        <p class="workflow-card__desc">{{ path.desc }}</p>
        <ul class="workflow-card__highlights">
          {% for h in path.highlights %}
          <li>{{ h }}</li>
          {% endfor %}
        </ul>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# ===== Document Types ===== #}
  {% if sections.doc_types %}
  <section class="doc-types">
    <div class="doc-types-inner">
      <div class="doc-types-header">
        <span class="section-label">{{ sections.doc_types.label }}</span>
        <h2 class="section-title">{{ sections.doc_types.heading }}</h2>
        <p class="section-subtitle" style="margin-left:auto;margin-right:auto;">{{ sections.doc_types.description }}</p>
      </div>
      <div class="doc-type-grid">
        {% for dt in sections.doc_types.types %}
        <a href="/demo/{{ dt.slug }}/" class="doc-type-card">
          <div class="doc-type-card__icon">{{ dt.icon }}</div>
          <div class="doc-type-card__name">{{ dt.name }}</div>
          <div class="doc-type-card__slug">{{ dt.slug }}</div>
          <div class="doc-type-card__desc">{{ dt.desc }}</div>
        </a>
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}

  {# ===== Comparison ===== #}
  {% if sections.comparison %}
  <section class="comparison">
    <div class="comparison-header">
      <span class="section-label">{{ sections.comparison.label }}</span>
      <h2 class="section-title">{{ sections.comparison.heading }}</h2>
      <p class="section-subtitle" style="margin-left:auto;margin-right:auto;">{{ sections.comparison.description }}</p>
    </div>
    <div class="compare-grid">
      <div class="compare-card compare-card--old">
        <span class="compare-card__label">{{ sections.comparison.old_label }}</span>
        <h3>{{ sections.comparison.old_title }}</h3>
        <p class="compare-card__subtitle">{{ sections.comparison.old_subtitle }}</p>
        <ul class="compare-card__list">
          {% for point in sections.comparison.old_points %}
          <li>{{ point }}</li>
          {% endfor %}
        </ul>
      </div>
      <div class="compare-divider">vs</div>
      <div class="compare-card compare-card--new">
        <span class="compare-card__label">{{ sections.comparison.new_label }}</span>
        <h3>{{ sections.comparison.new_title }}</h3>
        <p class="compare-card__subtitle">{{ sections.comparison.new_subtitle }}</p>
        <ul class="compare-card__list">
          {% for point in sections.comparison.new_points %}
          <li>{{ point }}</li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </section>
  {% endif %}

  {# ===== Numbers ===== #}
  {% if sections.numbers %}
  <section class="numbers-strip">
    <div class="numbers-inner">
      {% for n in sections.numbers %}
      <div>
        <div class="num-value">{{ n.value }}</div>
        <div class="num-label">{{ n.label }}</div>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# ===== Ecosystem ===== #}
  {% if sections.ecosystem %}
  <section class="ecosystem">
    <div class="ecosystem-header">
      <span class="section-label">{{ sections.ecosystem.label }}</span>
      <h2 class="section-title">{{ sections.ecosystem.heading }}</h2>
      <p class="section-subtitle" style="margin-left:auto;margin-right:auto;">{{ sections.ecosystem.description }}</p>
    </div>
    <div class="ecosystem-grid">
      {% for tool in sections.ecosystem.tools %}
      <a href="{{ tool.url }}" class="ecosystem-card" target="_blank" rel="noopener">
        <div class="ecosystem-card__name">{{ tool.name }}</div>
        <div class="ecosystem-card__desc">{{ tool.desc }}</div>
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# ===== Bottom CTA ===== #}
  <section class="bottom-cta">
    <div class="cta-inner">
      <h2>{{ sections.bottom_cta.heading }}</h2>
      <p>{{ sections.bottom_cta.description }}</p>
      <a href="{{ sections.bottom_cta.button_url }}" class="btn-primary">{{ sections.bottom_cta.button_label }}</a>
    </div>
  </section>
</body>
</html>
