<!DOCTYPE html>
<html lang="{{ locale }}" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ meta.title }}</title>
  <!-- META_INJECT -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      corePlugins: { preflight: false },
      theme: {
        extend: {
          colors: {
            brand: 'var(--accent)',
            paper: 'var(--bg-elevated)',
            ink: 'var(--text-primary)',
            subtle: 'var(--text-secondary)',
            line: 'var(--border)',
          },
          fontFamily: {
            display: ['var(--font-display)'],
            body: ['var(--font-body)'],
            mono: ['var(--font-mono)'],
          },
        },
      },
    };
  </script>
  <style>
    /* ===== Design Tokens — Dark Theme (default) ===== */
    :root {
      --bg-primary: #21211e;
      --bg-secondary: #2a2a27;
      --bg-tertiary: #33332f;
      --bg-code: #1c1c1a;
      --bg-elevated: #353532;
      --text-primary: #e6e2d8;
      --text-secondary: #b5b0a4;
      --text-muted: #7a766a;
      --text-heading: #f0ece2;
      --accent: #3B6DA5;
      --accent-hover: #4A80BA;
      --accent-dim: #2A5480;
      --accent-glow: rgba(59, 109, 165, 0.12);
      --accent-2: #D4785A;
      --accent-2-hover: #e0886a;
      --green: #7b9e6d;
      --red: #c06a5a;
      --orange: #c98d4e;
      --border: #3a3832;
      --border-light: #2e2d28;
      --font-display: "Noto Serif SC", "Source Han Serif SC", "Songti SC", serif;
      --font-body: "Inter", "Noto Sans SC", "PingFang SC", sans-serif;
      --font-mono: "IBM Plex Mono", "SFMono-Regular", monospace;
      --space-xs: 0.25rem; --space-sm: 0.5rem; --space-md: 1rem;
      --space-lg: 1.5rem; --space-xl: 2rem; --space-2xl: 3rem;
      --space-3xl: 4rem; --space-4xl: 6rem;
      --radius-sm: 6px; --radius: 10px; --radius-lg: 16px; --radius-xl: 24px;
      --max-width: 1100px; --max-width-text: 720px; --nav-height: 64px;
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.3);
      --shadow: 0 4px 16px rgba(0,0,0,0.4);
      --shadow-lg: 0 8px 32px rgba(0,0,0,0.5);
      --transition: 200ms ease;
      --transition-slow: 350ms ease;
    }

    [data-theme="light"] {
      --bg-primary: #f8f5ee;
      --bg-secondary: #f2efe6;
      --bg-tertiary: #ebe7dc;
      --bg-code: #f0ede4;
      --bg-elevated: #FAF8F4;
      --text-primary: #2d2a22;
      --text-secondary: #5c574a;
      --text-muted: #8c8676;
      --text-heading: #1a1812;
      --accent: #244C7A;
      --accent-hover: #1a3a5e;
      --accent-dim: #4A7DB5;
      --accent-glow: rgba(36, 76, 122, 0.08);
      --accent-2: #B65C3A;
      --accent-2-hover: #9a4d30;
      --border: #d8d4c8;
      --border-light: #e8e4dc;
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.06);
      --shadow: 0 4px 16px rgba(0,0,0,0.1);
      --shadow-lg: 0 8px 32px rgba(0,0,0,0.12);
    }

    /* ===== Reset & Base ===== */
    *,*::before,*::after { box-sizing:border-box; margin:0; padding:0; }
    html { scroll-behavior:smooth; -webkit-text-size-adjust:100%; text-size-adjust:100%; }
    body {
      font-family:var(--font-body);
      font-size:1.0625rem;
      line-height:1.7;
      color:var(--text-primary);
      background-color:var(--bg-primary);
      -webkit-font-smoothing:antialiased;
      -moz-osx-font-smoothing:grayscale;
      transition:background-color var(--transition-slow),color var(--transition-slow);
    }
    ::selection { background:var(--accent-dim); color:var(--bg-primary); }
    h1,h2,h3,h4 { font-family:var(--font-display); font-weight:600; line-height:1.25; color:var(--text-heading); }
    h1 { font-size:clamp(2.5rem,5vw,3.8rem); letter-spacing:-0.02em; }
    h2 { font-size:clamp(1.8rem,3.5vw,2.5rem); letter-spacing:-0.01em; }
    h3 { font-size:clamp(1.3rem,2.5vw,1.7rem); }
    h4 { font-size:1.15rem; }
    a { color:var(--accent); text-decoration:none; transition:color var(--transition); }
    a:hover { color:var(--accent-hover); }
    code { font-family:var(--font-mono); font-size:0.85em; background:var(--bg-code); padding:0.15em 0.4em; border-radius:4px; color:var(--accent); border:1px solid var(--border-light); }

    /* ===== Container utility ===== */
    .container { max-width:var(--max-width); margin:0 auto; padding:0 var(--space-xl); }
    .container--text { max-width:var(--max-width-text); }

    /* ===== Section ===== */
    .section { padding:var(--space-4xl) 0; }

    /* ===== Hero background glow ===== */
    .hero-glow::before {
      content:''; position:absolute; top:-50%; left:50%; transform:translateX(-50%);
      width:800px; height:800px;
      background:radial-gradient(circle,var(--accent-glow) 0%,transparent 70%);
      pointer-events:none;
    }
    /* ===== Workflow card list bullet ===== */
    .workflow-highlights li::before {
      content: '';
      position: absolute;
      left: 0; top: 11px;
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--accent);
    }

    /* ===== CTA background glow ===== */
    .cta-glow::before {
      content:''; position:absolute; bottom:-40%; left:50%; transform:translateX(-50%);
      width:600px; height:600px;
      background:radial-gradient(circle,var(--accent-glow) 0%,transparent 70%);
      pointer-events:none;
    }

    @media (max-width:860px) {
      .section { padding:var(--space-2xl) 0; }
    }
    @media print { .theme-toggle { display:none !important; } }
  </style>
</head>
<body>
  <!-- NAV_INJECT -->

  <button class="theme-toggle fixed right-6 top-5 z-[200] flex h-9 w-9 items-center justify-center rounded-full border border-line bg-[var(--bg-primary)] text-base text-[var(--text-secondary)] transition-all duration-200 hover:border-brand hover:text-brand" id="themeToggle" aria-label="Toggle theme" title="Toggle theme">&#9788;</button>

  <main>

    {# ===== Hero ===== #}
    <section class="hero-glow relative overflow-hidden px-[var(--space-xl)] pt-[calc(var(--nav-height)+var(--space-4xl)+2rem)] pb-[var(--space-4xl)] text-center max-md:px-[var(--space-md)] max-md:pt-[calc(var(--nav-height)+var(--space-3xl))] max-md:pb-[var(--space-2xl)]">
      <div class="container mx-auto max-w-[var(--max-width)] px-[var(--space-xl)]">
        {% if sections.hero.badge %}<p class="relative mb-[var(--space-lg)] font-mono text-[0.85rem] uppercase tracking-[0.15em] text-brand">{{ sections.hero.badge }}</p>{% endif %}
        <h1 class="relative mb-[var(--space-lg)] text-[clamp(2.8rem,6vw,4.5rem)] font-extrabold leading-[1.1] [&_em]:italic [&_em]:text-brand">{{ sections.hero.headline }}</h1>
        <p class="relative mx-auto mb-[var(--space-2xl)] max-w-[var(--max-width-text)] text-[1.25rem] text-[var(--text-secondary)]">{{ sections.hero.description }}</p>
        <div class="relative flex justify-center gap-[var(--space-md)] flex-wrap max-md:flex-col max-md:items-center">
          {% for btn in sections.hero.cta_buttons %}
          <a href="{{ btn.url }}" class="inline-flex items-center gap-[var(--space-sm)] rounded-[var(--radius)] px-7 py-3 font-body text-[1rem] font-semibold no-underline transition-all duration-200 {% if btn.style == 'btn-primary' %}bg-brand text-white hover:bg-[var(--accent-hover)] hover:text-white hover:-translate-y-px hover:shadow-[0_4px_20px_var(--accent-glow)]{% else %}border-[1.5px] border-line bg-transparent text-ink hover:border-brand hover:text-brand hover:-translate-y-px{% endif %}">{{ btn.label }}</a>
          {% endfor %}
        </div>
        {% if sections.hero.pipeline %}
        <div class="relative mt-[var(--space-4xl)] flex items-center justify-center gap-[var(--space-md)] flex-wrap max-sm:flex-col max-sm:gap-[var(--space-sm)] max-md:mt-[var(--space-2xl)]">
          {% for item in sections.hero.pipeline %}
          {% if not loop.first %}<span class="font-mono text-[1.5rem] text-[var(--accent-dim)] max-sm:rotate-90">&rarr;</span>{% endif %}
          <div class="rounded-[var(--radius)] border border-line bg-[var(--bg-secondary)] px-[var(--space-xl)] py-[var(--space-md)] text-center font-mono text-[0.9rem] text-ink transition-all duration-200 hover:-translate-y-0.5 hover:border-brand hover:shadow-[var(--shadow)]">
            <div class="font-bold text-brand">{{ item.label }}</div>
            <div class="mt-[2px] text-[0.75rem] text-[var(--text-muted)]">{{ item.desc }}</div>
          </div>
          {% endfor %}
        </div>
        {% endif %}
      </div>
    </section>

    {# ===== Features ===== #}
    <section class="features section bg-[var(--bg-secondary)]">
      <div class="container mx-auto max-w-[var(--max-width)] px-[var(--space-xl)]">
        <div class="section-header mx-auto mb-[var(--space-3xl)] text-center">
          {% if sections.features.label %}<span class="mb-[var(--space-md)] block font-mono text-[0.8rem] font-medium uppercase tracking-[0.12em] text-brand">{{ sections.features.label }}</span>{% endif %}
          <h2 class="mb-[var(--space-md)]">{{ sections.features.heading }}</h2>
          <p class="mx-auto max-w-[var(--max-width-text)] text-[1.2rem] text-[var(--text-secondary)]">{{ sections.features.description }}</p>
        </div>
        <div class="grid grid-cols-[repeat(auto-fit,minmax(320px,1fr))] gap-[var(--space-xl)] max-md:grid-cols-1">
          {% for feat in sections.features.cards %}
          <article class="relative overflow-hidden rounded-[var(--radius-lg)] border border-[var(--border-light)] bg-[var(--bg-elevated)] p-[var(--space-2xl)] transition-all duration-350 hover:-translate-y-[3px] hover:border-[var(--border)] hover:shadow-[var(--shadow)] before:absolute before:left-0 before:right-0 before:top-0 before:h-[3px] before:bg-gradient-to-r before:from-brand before:to-transparent before:opacity-0 before:transition-opacity before:duration-350 hover:before:opacity-100">
            <div class="mb-[var(--space-lg)] flex h-11 w-11 items-center justify-center rounded-[var(--radius)] border border-line bg-[var(--bg-code)] font-mono text-[1.2rem] {% if feat.icon_class == 'charts' or feat.icon_class == 'mcp' %}text-[var(--accent-2)]{% elif feat.icon_class == 'diagrams' or feat.icon_class == 'print' %}text-[var(--green)]{% else %}text-brand{% endif %}">{{ feat.icon }}</div>
            <h3 class="mb-[var(--space-sm)] text-[1.3rem]">{{ feat.title }}</h3>
            <p class="!mb-0 text-[0.95rem] text-[var(--text-secondary)]">{{ feat.description }}</p>
          </article>
          {% endfor %}
        </div>
      </div>
    </section>

    {# ===== Workflows ===== #}
    {% if sections.workflows %}
    <section class="section">
      <div class="container mx-auto max-w-[var(--max-width)] px-[var(--space-xl)]">
        <div class="section-header mx-auto mb-[var(--space-3xl)] text-center">
          <span class="mb-[var(--space-md)] block font-mono text-[0.8rem] font-medium uppercase tracking-[0.12em] text-brand">{{ sections.workflows.label }}</span>
          <h2 class="mb-[var(--space-md)]">{{ sections.workflows.heading }}</h2>
          <p class="mx-auto max-w-[var(--max-width-text)] text-[1.2rem] text-[var(--text-secondary)]">{{ sections.workflows.description }}</p>
        </div>
        <div class="grid grid-cols-[repeat(auto-fit,minmax(300px,1fr))] gap-[var(--space-xl)] max-md:grid-cols-1">
          {% for path in sections.workflows.paths %}
          <div class="relative overflow-hidden rounded-[var(--radius-lg)] border border-[var(--border-light)] bg-[var(--bg-secondary)] p-[var(--space-2xl)] transition-all duration-350 hover:-translate-y-[3px] hover:border-[var(--border)] hover:shadow-[var(--shadow)] before:absolute before:left-0 before:right-0 before:top-0 before:h-[3px] before:bg-gradient-to-r before:from-[var(--accent-2)] before:to-transparent before:opacity-0 before:transition-opacity before:duration-350 hover:before:opacity-100">
            <div class="mb-[var(--space-md)] font-display text-[2.5rem] font-bold leading-none text-line">{{ path.num }}</div>
            {% if path.tag %}<span class="mb-[var(--space-md)] inline-block rounded-xl border border-[var(--border-light)] bg-[var(--bg-code)] px-[10px] py-[2px] font-mono text-[0.7rem] font-semibold uppercase tracking-[0.05em] text-brand">{{ path.tag }}</span>{% endif %}
            <h3 class="mb-[var(--space-xs)] text-[1.25rem]">{{ path.title }}</h3>
            <p class="mb-[var(--space-md)] font-mono text-[0.8rem] text-[var(--text-muted)]">{{ path.subtitle }}</p>
            <p class="mb-[var(--space-lg)] text-[0.95rem] leading-[1.65] text-[var(--text-secondary)]">{{ path.desc }}</p>
            <ul class="workflow-highlights list-none border-t border-[var(--border-light)] pl-4 pt-[var(--space-md)]">
              {% for h in path.highlights %}
              <li class="relative py-[var(--space-xs)] pl-5 text-[0.9rem] text-[var(--text-secondary)]">{{ h }}</li>
              {% endfor %}
            </ul>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>
    {% endif %}

    {# ===== Document Types ===== #}
    {% if sections.doc_types %}
    <section class="doc-types section bg-[var(--bg-secondary)]">
      <div class="container mx-auto max-w-[var(--max-width)] px-[var(--space-xl)]">
        <div class="section-header mx-auto mb-[var(--space-3xl)] text-center">
          <span class="mb-[var(--space-md)] block font-mono text-[0.8rem] font-medium uppercase tracking-[0.12em] text-brand">{{ sections.doc_types.label }}</span>
          <h2 class="mb-[var(--space-md)]">{{ sections.doc_types.heading }}</h2>
          <p class="mx-auto max-w-[var(--max-width-text)] text-[1.2rem] text-[var(--text-secondary)]">{{ sections.doc_types.description }}</p>
        </div>
        <div class="grid grid-cols-5 gap-[var(--space-sm)] max-lg:grid-cols-3 max-md:grid-cols-2 max-sm:grid-cols-2">
          {% for dt in sections.doc_types.types %}
          <a href="/demo/{{ dt.slug }}/" class="block rounded-[var(--radius)] border border-line bg-[var(--bg-elevated)] px-[var(--space-md)] py-[var(--space-lg)] text-center no-underline transition-all duration-200 hover:-translate-y-0.5 hover:border-brand hover:shadow-[var(--shadow-sm)]">
            <div class="mx-auto mb-[var(--space-sm)] flex h-8 w-8 items-center justify-center rounded-[var(--radius-sm)] border border-[var(--border-light)] bg-[var(--bg-code)] font-display text-[0.9rem] font-semibold text-brand">{{ dt.icon }}</div>
            <div class="mb-[2px] font-body text-[0.8rem] font-semibold text-[var(--text-heading)]">{{ dt.name }}</div>
            <div class="mb-[var(--space-xs)] font-mono text-[0.65rem] text-[var(--text-muted)]">{{ dt.slug }}</div>
            <div class="text-[0.7rem] leading-[1.4] text-[var(--text-muted)]">{{ dt.desc }}</div>
          </a>
          {% endfor %}
        </div>
      </div>
    </section>
    {% endif %}

    {# ===== Comparison ===== #}
    {% if sections.comparison %}
    <section class="comparison section overflow-hidden">
      <div class="container mx-auto max-w-[var(--max-width)] px-[var(--space-xl)]">
        <div class="section-header mx-auto mb-[var(--space-3xl)] text-center">
          <span class="mb-[var(--space-md)] block font-mono text-[0.8rem] font-medium uppercase tracking-[0.12em] text-brand">{{ sections.comparison.label }}</span>
          <h2 class="mb-[var(--space-md)]">{{ sections.comparison.heading }}</h2>
          <p class="mx-auto max-w-[var(--max-width-text)] text-[1.2rem] text-[var(--text-secondary)]">{{ sections.comparison.description }}</p>
        </div>
        <div class="mt-[var(--space-2xl)] grid grid-cols-[1fr_auto_1fr] items-start gap-[var(--space-2xl)] max-md:grid-cols-1">
          <div class="compare-card--old rounded-[var(--radius-lg)] border border-[var(--border-light)] bg-[var(--bg-secondary)] p-[var(--space-2xl)] opacity-70 transition-all duration-350">
            <span class="mb-[var(--space-md)] block font-mono text-[0.75rem] uppercase tracking-[0.1em] text-[var(--text-muted)]">{{ sections.comparison.old_label }}</span>
            <h3 class="mb-[var(--space-md)] text-[1.5rem]">{{ sections.comparison.old_title }}</h3>
            <p class="mb-[var(--space-lg)] text-[0.9rem] text-[var(--text-secondary)]">{{ sections.comparison.old_subtitle }}</p>
            <ul class="list-none pl-0">
              {% for point in sections.comparison.old_points %}
              <li class="relative py-[var(--space-sm)] pl-[var(--space-xl)] text-[0.95rem] text-[var(--text-secondary)] before:absolute before:left-0 before:font-bold before:text-[var(--red)] before:content-['✗']">{{ point }}</li>
              {% endfor %}
            </ul>
          </div>
          <div class="flex items-center justify-center px-0 py-[var(--space-md)] font-mono text-[1.2rem] text-brand max-md:rotate-90 max-md:px-0 max-md:py-0">vs</div>
          <div class="compare-card--new rounded-[var(--radius-lg)] border border-[var(--accent-dim)] bg-[var(--bg-secondary)] p-[var(--space-2xl)] shadow-[0_0_40px_var(--accent-glow)] transition-all duration-350">
            <span class="mb-[var(--space-md)] block font-mono text-[0.75rem] font-semibold uppercase tracking-[0.1em] text-brand">{{ sections.comparison.new_label }}</span>
            <h3 class="mb-[var(--space-md)] text-[1.5rem]">{{ sections.comparison.new_title }}</h3>
            <p class="mb-[var(--space-lg)] text-[0.9rem] text-[var(--text-secondary)]">{{ sections.comparison.new_subtitle }}</p>
            <ul class="list-none pl-0">
              {% for point in sections.comparison.new_points %}
              <li class="relative py-[var(--space-sm)] pl-[var(--space-xl)] text-[0.95rem] text-[var(--text-secondary)] before:absolute before:left-0 before:font-bold before:text-[var(--green)] before:content-['✓']">{{ point }}</li>
              {% endfor %}
            </ul>
          </div>
        </div>
      </div>
    </section>
    {% endif %}

    {# ===== Numbers ===== #}
    {% if sections.numbers %}
    <section class="section">
      <div class="container mx-auto max-w-[var(--max-width)] px-[var(--space-xl)]">
        <div class="grid grid-cols-4 gap-[var(--space-lg)] rounded-[var(--radius-lg)] border border-line bg-[var(--bg-secondary)] p-[var(--space-2xl)] text-center max-md:grid-cols-2 max-md:gap-y-[var(--space-xl)] max-sm:grid-cols-1">
          {% for n in sections.numbers %}
          <div>
            <div class="mb-[var(--space-xs)] font-display text-[2.5rem] font-bold leading-[1.1] text-brand">{{ n.value }}</div>
            <div class="font-mono text-[0.8rem] uppercase tracking-[0.06em] text-[var(--text-muted)]">{{ n.label }}</div>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>
    {% endif %}

    {# ===== Ecosystem ===== #}
    {% if sections.ecosystem %}
    <section class="ecosystem section bg-[var(--bg-secondary)]">
      <div class="container mx-auto max-w-[var(--max-width)] px-[var(--space-xl)]">
        <div class="section-header mx-auto mb-[var(--space-3xl)] text-center">
          <span class="mb-[var(--space-md)] block font-mono text-[0.8rem] font-medium uppercase tracking-[0.12em] text-brand">{{ sections.ecosystem.label }}</span>
          <h2 class="mb-[var(--space-md)]">{{ sections.ecosystem.heading }}</h2>
          <p class="mx-auto max-w-[var(--max-width-text)] text-[1.2rem] text-[var(--text-secondary)]">{{ sections.ecosystem.description }}</p>
        </div>
        <div class="grid grid-cols-[repeat(auto-fit,minmax(180px,1fr))] gap-[var(--space-md)]">
          {% for tool in sections.ecosystem.tools %}
          <a href="{{ tool.url }}" class="block rounded-[var(--radius)] border border-line bg-[var(--bg-elevated)] px-[var(--space-xl)] py-[var(--space-xl)] text-center no-underline transition-all duration-200 hover:-translate-y-0.5 hover:border-brand hover:shadow-[var(--shadow-sm)]" target="_blank" rel="noopener">
            <div class="mb-[var(--space-xs)] font-display text-[1.1rem] font-semibold text-[var(--text-heading)]">{{ tool.name }}</div>
            <div class="text-[0.85rem] leading-[1.4] text-[var(--text-muted)]">{{ tool.desc }}</div>
          </a>
          {% endfor %}
        </div>
      </div>
    </section>
    {% endif %}

    {# ===== CTA ===== #}
    <section class="cta section cta-glow relative overflow-hidden text-center">
      <div class="container mx-auto max-w-[var(--max-width)] px-[var(--space-xl)]">
        <h2 class="cta__title relative mb-[var(--space-md)] text-[clamp(1.8rem,4vw,2.5rem)]">{{ sections.bottom_cta.heading }}</h2>
        <p class="relative mb-[var(--space-2xl)] text-[1.15rem] text-[var(--text-secondary)]">{{ sections.bottom_cta.description }}</p>
        <div class="relative flex justify-center gap-[var(--space-md)] flex-wrap">
          <a href="{{ sections.bottom_cta.button_url }}" class="inline-flex items-center gap-[var(--space-sm)] rounded-[var(--radius)] bg-brand px-7 py-3 font-body text-[1rem] font-semibold text-white no-underline transition-all duration-200 hover:bg-[var(--accent-hover)] hover:text-white hover:-translate-y-px hover:shadow-[0_4px_20px_var(--accent-glow)]">{{ sections.bottom_cta.button_label }}</a>
        </div>
      </div>
    </section>

  </main>

  <!-- FOOTER_INJECT -->

  <script>
    (function() {
      const KEY = 'momo-theme';
      const toggle = document.getElementById('themeToggle');
      const html = document.documentElement;
      if (document.getElementById('navThemeToggle')) { toggle.style.display = 'none'; }
      function setIcon(t) { toggle.innerHTML = t === 'light' ? '&#9790;' : '&#9788;'; }
      const s = localStorage.getItem(KEY);
      if (s) html.setAttribute('data-theme', s);
      else localStorage.setItem(KEY, 'dark');
      setIcon(html.getAttribute('data-theme'));
      toggle.addEventListener('click', function() {
        const n = html.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
        html.setAttribute('data-theme', n);
        localStorage.setItem(KEY, n);
        setIcon(n);
      });
    })();
  </script>
</body>
</html>
