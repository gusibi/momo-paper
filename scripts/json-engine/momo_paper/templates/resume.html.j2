{% extends "_base.html.j2" %}
{% block title %}Momo Paper · Resume · {{ meta.title }}{% endblock %}
{% block extra_css %}
  <style>
    .exp-item li::before {
      content: "·";
      position: absolute;
      left: 0;
      color: var(--brand);
      font-weight: bold;
    }
  </style>
{% endblock %}
{% block content %}
  <header class="mb-[var(--space-3xl)] text-left">
    <p class="block mb-[var(--space-sm)] font-mono text-[0.75rem] font-medium uppercase tracking-[0.08em] text-brand">{{ meta.eyebrow | default('Momo Paper / resume / ' + locale) }}</p>
    <h1>{{ meta.title }}</h1>
    <p class="max-w-full text-[1.1rem] text-subtle md:max-w-[var(--max-width-text)]">{{ meta.subtitle }}</p>
  </header>

  {% if sections.profile %}
  <div class="mb-10">
    <h2 class="!text-[18px] !mb-4">{% if locale == 'zh-CN' %}简介{% else %}Profile{% endif %}</h2>
    <p>{{ sections.profile.summary }}</p>
  </div>
  {% endif %}

  {% if sections.experience %}
  <div class="mb-10">
    <h2 class="!text-[18px] !mb-4">{% if locale == 'zh-CN' %}经历{% else %}Experience{% endif %}</h2>
    {% for exp in sections.experience %}
    <div class="mb-6">
      <div class="mb-2 flex items-baseline justify-between">
        <div>
          <div class="text-[15px] font-semibold">{{ exp.role }}</div>
          <div class="text-[14px] text-subtle">{{ exp.company }}</div>
        </div>
        <div class="font-mono text-[12px] text-subtle">{{ exp.period }}</div>
      </div>
      {% if exp.highlights %}
      <ul class="list-none pl-0">
        {% for hl in exp.highlights %}
        <li class="relative mb-[6px] pl-4 text-[14px] text-ink">{{ hl }}</li>
        {% endfor %}
      </ul>
      {% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if sections.projects %}
  <div class="mb-10">
    <h2 class="!text-[18px] !mb-4">{% if locale == 'zh-CN' %}代表成果{% else %}Selected Work{% endif %}</h2>
    {% for proj in sections.projects %}
    <div class="mb-6">
      <div class="text-[15px] font-semibold">{{ proj.name }}</div>
      <p>{{ proj.description }}</p>
      {% if proj.impact %}<p class="text-[13px] text-subtle"><strong>{% if locale == 'zh-CN' %}影响：{% else %}Impact: {% endif %}</strong>{{ proj.impact }}</p>{% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if sections.education %}
  <div class="mb-10">
    <h2 class="!text-[18px] !mb-4">{% if locale == 'zh-CN' %}教育背景{% else %}Education{% endif %}</h2>
    {% for edu in sections.education %}
    <div class="mb-6">
      <div class="mb-2 flex items-baseline justify-between">
        <div>
          <div class="text-[15px] font-semibold">{{ edu.degree }}</div>
          <div class="text-[14px] text-subtle">{{ edu.school }}</div>
        </div>
        <div class="font-mono text-[12px] text-subtle">{{ edu.year }}</div>
      </div>
    </div>
    {% endfor %}
  </div>
  {% endif %}
{% endblock %}
{% block footer %}
  <div class="mt-[var(--space-2xl)] flex flex-wrap justify-between gap-[var(--space-sm)] border-t border-[var(--border-light)] pt-[var(--space-lg)] font-mono text-[0.75rem] text-[var(--text-muted)] max-md:flex-col">
    <span>{{ meta.location | default('') }}</span>
    <span>{{ meta.email | default('') }}{% if meta.website %} | {{ meta.website }}{% endif %}</span>
  </div>
{% endblock %}
