{% extends "_base.html.j2" %}
{% block title %}Momo Paper · Long Doc · {{ meta.title }}{% endblock %}
{% block extra_css %}{% endblock %}
{% block content %}
  <header class="mb-[var(--space-3xl)] text-left">
    <p class="block mb-[var(--space-sm)] font-mono text-[0.75rem] font-medium uppercase tracking-[0.08em] text-brand">{{ meta.eyebrow | default('Momo Paper / long_doc / ' + locale) }}</p>
    <h1>{{ meta.title }}</h1>
    <p class="max-w-full text-[1.1rem] text-subtle md:max-w-[var(--max-width-text)]">{{ meta.subtitle }}</p>
  </header>

  {% if sections.abstract %}
  <section>
    <h2>{% if locale == 'zh-CN' %}摘要{% else %}Abstract{% endif %}</h2>
    {% for para in sections.abstract.body %}
    <p>{{ para }}</p>
    {% endfor %}
    {% if sections.abstract.findings %}
    <ul class="my-[var(--space-xl)] list-none rounded-[0_var(--radius)_var(--radius)_0] border-l-[3px] border-l-brand bg-surface2 p-[var(--space-lg)_var(--space-xl)] pl-0">
      {% for f in sections.abstract.findings %}
      <li class="relative mb-[var(--space-sm)] pl-[var(--space-xl)] text-[0.95rem] leading-[1.6] text-ink before:absolute before:left-[4px] before:top-[10px] before:h-[6px] before:w-[6px] before:rounded-full before:bg-[var(--accent-2)] before:content-[''] last:mb-0">{{ f }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </section>
  {% endif %}

  {% for sec in sections.sections %}
  <section>
    <h2>{{ sec.heading }}</h2>
    {% for para in sec.body %}
    <p>{{ para }}</p>
    {% endfor %}
    {% if sec.code_blocks %}
    {% for block in sec.code_blocks %}
    <div class="my-[var(--space-xl)] overflow-hidden rounded-[var(--radius)] border border-line bg-[var(--bg-code)]">
      {% if block.language %}<div class="border-b border-[var(--border-light)] bg-[var(--bg-tertiary)] px-[var(--space-md)] py-[var(--space-sm)] font-mono text-[0.7rem] font-semibold uppercase tracking-[0.06em] text-[var(--text-muted)]">{{ block.language }}</div>{% endif %}
      <pre class="m-0 overflow-x-auto whitespace-pre rounded-none border-none bg-transparent px-[var(--space-xl)] py-[var(--space-lg)] font-mono text-[0.85rem] leading-[1.65] text-ink"><code>{{ block.content }}</code></pre>
    </div>
    {% endfor %}
    {% endif %}
    {% if sec.quote %}
    <div class="my-6 rounded-[0_6px_6px_0] border-l-[3px] border-l-brand bg-[var(--canvas)] px-6 py-5 italic">
      <div class="text-[16px] leading-[1.6] text-ink">"{{ sec.quote.text }}"</div>
      {% if sec.quote.source %}<div class="mt-[10px] font-mono text-[11px] not-italic text-subtle">— {{ sec.quote.source }}</div>{% endif %}
    </div>
    {% endif %}
  </section>
  {% endfor %}

  {% if sections.conclusion %}
  <section>
    <h2>{% if locale == 'zh-CN' %}结论{% else %}Conclusion{% endif %}</h2>
    {% for para in sections.conclusion.body %}
    <p>{{ para }}</p>
    {% endfor %}
    {% if sections.conclusion.next_steps %}
    <ul class="my-[var(--space-md)] list-none pl-0">
      {% for step in sections.conclusion.next_steps %}
      <li class="relative mb-[var(--space-sm)] pl-[var(--space-xl)] text-[0.95rem] leading-[1.6] text-subtle before:absolute before:left-0 before:font-bold before:text-[var(--green)] before:content-['✓']">{{ step }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </section>
  {% endif %}
{% endblock %}
{% block footer %}
  <div class="mt-[var(--space-2xl)] flex flex-wrap justify-between gap-[var(--space-sm)] border-t border-[var(--border-light)] pt-[var(--space-lg)] font-mono text-[0.75rem] text-[var(--text-muted)] max-md:flex-col">
    <span>{{ meta.date | default('') }}</span>
    <span>{{ meta.author | default('') }}</span>
  </div>
{% endblock %}
