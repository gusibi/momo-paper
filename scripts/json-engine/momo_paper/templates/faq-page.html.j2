{% extends "_base.html.j2" %}
{% block title %}Momo Paper · FAQ · {{ meta.title }}{% endblock %}
{% block extra_css %}{% endblock %}
{% block content %}
  <header class="mb-[var(--space-3xl)] text-left">
    <p class="block mb-[var(--space-sm)] font-mono text-[0.75rem] font-medium uppercase tracking-[0.08em] text-brand">{{ meta.eyebrow | default('Momo Paper / faq_page / ' + locale) }}</p>
    <h1>{{ meta.title }}</h1>
    <p class="max-w-full text-[1.1rem] text-subtle md:max-w-[var(--max-width-text)]">{{ meta.subtitle }}</p>
  </header>

  {% if sections.lead %}
  <section>
    {% for para in sections.lead.body %}
    <p>{{ para }}</p>
    {% endfor %}
  </section>
  {% endif %}

  {% for group in sections.groups %}
  <div class="mb-8">
    <h3 class="font-display text-[18px] font-semibold text-ink mb-4">{{ group.title }}</h3>
    {% for item in group['items'] %}
    <div class="mb-4 rounded-lg border border-line bg-[var(--canvas)] p-4 md:p-5">
      <div class="mb-2 text-[15px] font-semibold text-ink">{{ item.question }}</div>
      <div class="text-[14px] leading-[1.6] text-subtle">{{ item.answer }}</div>
    </div>
    {% endfor %}
  </div>
  {% endfor %}

  {% if sections.summary %}
  <section>
    <h2>{% if locale == 'zh-CN' %}最终说明{% else %}Summary{% endif %}</h2>
    {% for para in sections.summary.body %}
    <p>{{ para }}</p>
    {% endfor %}
    {% if sections.summary.next_step %}
    <div class="relative my-[var(--space-xl)] rounded-[0_var(--radius)_var(--radius)_0] border-l-[3px] border-l-[var(--accent-2)] bg-surface2 p-[var(--space-lg)_var(--space-xl)] text-[0.95rem] leading-[1.7] text-ink before:mb-[var(--space-sm)] before:block before:font-mono before:text-[0.65rem] before:font-semibold before:uppercase before:tracking-[0.08em] before:text-[var(--accent-2)] before:content-['Insight']">{{ sections.summary.next_step }}</div>
    {% endif %}
  </section>
  {% endif %}
{% endblock %}
