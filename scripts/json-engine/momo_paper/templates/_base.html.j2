<!DOCTYPE html>
<html lang="{{ locale }}" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Momo Paper{% endblock %}</title>
  <!-- META_INJECT -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      corePlugins: {
        preflight: false,
      },
      theme: {
        extend: {
          colors: {
            surface0: 'var(--surface-0)',
            surface1: 'var(--surface-1)',
            surface2: 'var(--surface-2)',
            surface3: 'var(--surface-3)',
            brand: 'var(--brand)',
            paper: 'var(--paper)',
            ink: 'var(--ink)',
            subtle: 'var(--ink-subtle)',
            line: 'var(--line)',
          },
          fontFamily: {
            display: ['var(--font-display)'],
            body: ['var(--font-body)'],
            mono: ['var(--font-mono)'],
          },
          borderRadius: {
            sm: 'var(--radius-sm)',
            DEFAULT: 'var(--radius)',
            lg: 'var(--radius-lg)',
            xl: 'var(--radius-xl)',
          },
          boxShadow: {
            soft: 'var(--shadow-soft)',
            surface: 'var(--shadow-surface)',
          },
        },
      },
    };
  </script>
  <style>
    /* ============================================================
       Momo Paper — Design Tokens
       ============================================================ */

    /* ===== Dark Theme (default) ===== */
    :root {
      --bg-primary: #21211e;
      --bg-secondary: #2a2a27;
      --bg-tertiary: #33332f;
      --bg-code: #1c1c1a;
      --bg-elevated: #353532;
      --text-primary: #e6e2d8;
      --text-secondary: #b5b0a4;
      --text-muted: #7a766a;
      --text-heading: #f0ece2;
      --accent: #3B6DA5;
      --accent-hover: #4A80BA;
      --accent-dim: #2A5480;
      --accent-glow: rgba(59, 109, 165, 0.12);
      --accent-2: #D4785A;
      --accent-2-hover: #e0886a;
      --accent-2-dim: #8a4a35;
      --green: #7b9e6d;
      --red: #c06a5a;
      --orange: #c98d4e;
      --blue: #7b8faa;
      --border: #3a3832;
      --border-light: #2e2d28;
      --font-display: "Noto Serif SC", "Source Han Serif SC", "Songti SC", serif;
      --font-body: "Inter", "Noto Sans SC", "PingFang SC", sans-serif;
      --font-mono: "IBM Plex Mono", "SFMono-Regular", monospace;
      --space-xs: 0.25rem; --space-sm: 0.5rem; --space-md: 1rem;
      --space-lg: 1.5rem; --space-xl: 2rem; --space-2xl: 3rem;
      --space-3xl: 4rem; --space-4xl: 6rem;
      --radius-sm: 6px; --radius: 10px; --radius-lg: 16px; --radius-xl: 24px;
      --max-width: 1100px; --max-width-text: 720px; --nav-height: 64px;
      --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.3);
      --shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
      --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.5);
      --transition: 200ms ease;
      --transition-slow: 350ms ease;
      --canvas: var(--bg-secondary);
      --paper: var(--bg-elevated);
      --ink: var(--text-primary);
      --ink-subtle: var(--text-secondary);
      --line: var(--border);
      --brand: var(--accent);
      --brand-muted: var(--accent-glow);
      --accent-muted: var(--accent-2-dim);
      --font-sans: var(--font-body);
      --font-serif: var(--font-display);
      --card-padding: var(--space-lg);
      --success: var(--green);
      --danger: var(--red);
      --warning: var(--orange);
      --section-gap: 3.5rem;
      --shadow-soft: 0 2px 16px rgba(0, 0, 0, 0.18);
      --shadow-surface: 0 1px 2px rgba(0, 0, 0, 0.28), 0 6px 20px rgba(0, 0, 0, 0.35);
      --surface-0: var(--bg-primary);
      --surface-1: var(--bg-secondary);
      --surface-2: var(--bg-tertiary);
      --surface-3: var(--bg-elevated);
    }

    /* ===== Light Theme ===== */
    [data-theme="light"] {
      --bg-primary: #f8f5ee;
      --bg-secondary: #f2efe6;
      --bg-tertiary: #ebe7dc;
      --bg-code: #f0ede4;
      --bg-elevated: #FAF8F4;
      --text-primary: #2d2a22;
      --text-secondary: #5c574a;
      --text-muted: #8c8676;
      --text-heading: #1a1812;
      --accent: #244C7A;
      --accent-hover: #1a3a5e;
      --accent-dim: #4A7DB5;
      --accent-glow: rgba(36, 76, 122, 0.08);
      --accent-2: #B65C3A;
      --accent-2-hover: #9a4d30;
      --accent-2-dim: #d4a853;
      --border: #d8d4c8;
      --border-light: #e8e4dc;
      --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.06);
      --shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
      --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.12);
      --canvas: var(--bg-secondary);
      --paper: var(--bg-elevated);
      --ink: var(--text-primary);
      --ink-subtle: var(--text-secondary);
      --line: var(--border);
      --brand: var(--accent);
      --brand-muted: var(--accent-glow);
      --accent-muted: var(--accent-2-dim);
      --font-sans: var(--font-body);
      --font-serif: var(--font-display);
      --card-padding: var(--space-lg);
      --success: var(--green);
      --danger: var(--red);
      --warning: var(--orange);
      --section-gap: 3.5rem;
      --shadow-soft: 0 2px 16px rgba(0, 0, 0, 0.08);
      --shadow-surface: 0 1px 2px rgba(0, 0, 0, 0.04), 0 6px 20px rgba(0, 0, 0, 0.08);
      --surface-0: var(--bg-primary);
      --surface-1: var(--bg-secondary);
      --surface-2: var(--bg-tertiary);
      --surface-3: var(--bg-elevated);
    }

    /* ============================================================
       Reset & Base (element defaults, not class-based)
       ============================================================ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html {
      scroll-behavior: smooth;
      -webkit-text-size-adjust: 100%;
      text-size-adjust: 100%;
    }
    body {
      font-family: var(--font-body);
      font-size: 1.0625rem;
      line-height: 1.7;
      color: var(--text-primary);
      background-color: var(--bg-primary);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      transition: background-color var(--transition-slow), color var(--transition-slow);
      position: relative;
    }
    ::selection { background: var(--accent-dim); color: var(--bg-primary); }

    /* ===== Typography (element defaults) ===== */
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-display);
      font-weight: 600;
      line-height: 1.3;
      color: var(--text-heading);
    }
    h1 { font-size: clamp(1.8rem, 4vw, 2.4rem); letter-spacing: -0.01em; margin-bottom: var(--space-md); }
    h2 { font-size: clamp(1.4rem, 3vw, 1.9rem); letter-spacing: -0.005em; margin-bottom: var(--space-lg); }
    h3 { font-size: clamp(1.1rem, 2vw, 1.4rem); }
    h4 { font-size: 1.15rem; }
    p { margin-bottom: var(--space-lg); line-height: 1.75; }
    a { color: var(--accent); text-decoration: none; transition: color var(--transition); }
    a:hover { color: var(--accent-hover); }
    code {
      font-family: var(--font-mono);
      font-size: 0.85em;
      background: var(--bg-code);
      padding: 0.15em 0.4em;
      border-radius: 4px;
      color: var(--accent);
      border: 1px solid var(--border-light);
    }
    pre {
      font-family: var(--font-mono);
      background: var(--bg-code);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: var(--space-lg);
      overflow-x: auto;
      font-size: 0.875rem;
      line-height: 1.6;
      margin-bottom: var(--space-lg);
    }
    pre code {
      background: none; padding: 0; border: none;
      color: var(--text-primary); font-size: inherit;
    }
    strong { font-weight: 600; color: var(--text-heading); }
    ul, ol { padding-left: var(--space-xl); margin-bottom: var(--space-md); }
    li { margin-bottom: var(--space-sm); }
    li::marker { color: var(--accent-dim); }
    blockquote {
      border-left: 3px solid var(--accent);
      padding: var(--space-sm) var(--space-lg);
      margin: var(--space-lg) 0;
      color: var(--text-secondary);
      font-style: italic;
      background: var(--bg-tertiary);
      border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    }
    hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: var(--space-3xl) 0;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: var(--space-lg);
      font-size: 0.95rem;
    }
    th, td {
      padding: var(--space-sm) var(--space-md);
      text-align: left;
      border-bottom: 1px solid var(--border-light);
    }
    th {
      font-family: var(--font-display);
      font-weight: 600;
      color: var(--text-heading);
      border-bottom: 2px solid var(--border);
    }
    tr:hover td { background: var(--bg-secondary); }

    /* ===== Section heading accent underline (::after can't do via Tailwind variants universally) ===== */
    .docs-body h2 {
      margin-top: var(--space-3xl);
      margin-bottom: var(--space-lg);
      padding-bottom: var(--space-md);
      border-bottom: 1px solid var(--border);
      position: relative;
    }
    .docs-body h2::after {
      content: '';
      position: absolute;
      bottom: -1px; left: 0;
      width: 64px; height: 2px;
      background: var(--accent);
      border-radius: 1px;
    }
    .docs-body h2:first-of-type { margin-top: 0; }
    .docs-body h3 { margin-top: var(--space-2xl); margin-bottom: var(--space-md); }
    .docs-body p { line-height: 1.8; }

    /* ===== Counter‑based step numbers (Tailwind can't express counter()) ===== */
    .step-list {
      list-style: none;
      counter-reset: step;
      padding: 0;
      margin: var(--space-xl) 0;
    }
    .step-list li {
      position: relative;
      padding-left: 56px;
      margin-bottom: var(--space-xl);
      min-height: 40px;
    }
    .step-list li:last-child { margin-bottom: 0; }
    .step-list li::before {
      counter-increment: step;
      content: counter(step);
      position: absolute;
      left: 0; top: 0;
      width: 36px; height: 36px;
      background: var(--accent);
      color: var(--bg-primary);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-mono);
      font-size: 0.9rem;
      font-weight: 700;
    }

    /* ===== Print ===== */
    @media print {
      body { background: #fff; color: #000; }
      .docs { padding: 0; }
      .container { max-width: var(--max-width); margin: 0 auto; padding: 0 32px; }
      section, h2 { break-inside: avoid; page-break-inside: avoid; }
      .theme-toggle { display: none !important; }
    }

    /* ===== Responsive ===== */
    @media (max-width: 768px) {
      .docs-body h2 { margin-top: var(--space-xl); }
    }
  </style>
  {% block extra_css %}{% endblock %}
</head>
<body>
  <!-- NAV_INJECT -->

  <button class="theme-toggle fixed right-6 top-5 z-[200] flex h-9 w-9 items-center justify-center rounded-full border border-line bg-[var(--bg-primary)] text-base text-[var(--text-secondary)] transition-colors duration-200 hover:border-brand hover:text-brand" id="themeToggle" aria-label="Toggle theme" title="Toggle theme">&#9788;</button>

  <main class="docs px-0 pt-[calc(var(--nav-height)+var(--space-xl))] pb-[var(--space-2xl)] md:pt-[calc(var(--nav-height)+var(--space-2xl))] md:pb-[var(--space-4xl)]">
    <div class="container mx-auto max-w-[var(--max-width-text)] rounded-[var(--radius-sm)] bg-[var(--bg-secondary)] px-[var(--space-md)] py-[var(--space-xl)] md:px-[var(--space-2xl)] md:py-[var(--space-3xl)]">
      <div class="docs-body">
        {% block content %}{% endblock %}
      </div>
      {% block footer %}{% endblock %}
    </div>
  </main>

  <!-- FOOTER_INJECT -->

  <script>
    (function() {
      const KEY = 'momo-theme';
      const toggle = document.getElementById('themeToggle');
      const html = document.documentElement;

      if (document.getElementById('navThemeToggle')) { toggle.style.display = 'none'; }

      function setIcon(theme) { toggle.innerHTML = theme === 'light' ? '&#9790;' : '&#9788;'; }

      const stored = localStorage.getItem(KEY);
      if (stored) html.setAttribute('data-theme', stored);
      else localStorage.setItem(KEY, 'dark');
      setIcon(html.getAttribute('data-theme'));

      toggle.addEventListener('click', function() {
        const next = html.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
        html.setAttribute('data-theme', next);
        localStorage.setItem(KEY, next);
        setIcon(next);
      });
    })();
  </script>
</body>
</html>
