<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Momo Paper{% endblock %}</title>
  <!-- META_INJECT -->
  <style>
    /* ===== Design Tokens ===== */
    :root {
      --ink: #172033;
      --ink-subtle: #4C566A;
      --paper: #FAF8F4;
      --canvas: #F2EFE8;
      --line: #D8D2C4;
      --brand: #244C7A;
      --brand-muted: #DCE7F2;
      --accent: #B65C3A;
      --accent-muted: #F2E1D9;
      --success: #2F6B4F;
      --warning: #A46A21;
      --danger: #9A3D3D;
      --font-serif: "Noto Serif SC", "Source Han Serif SC", "Songti SC", serif;
      --font-sans: "Inter", "Noto Sans SC", "PingFang SC", sans-serif;
      --font-mono: "IBM Plex Mono", "SFMono-Regular", monospace;
      --content-width: 840px;
      --section-gap: 64px;
      --card-padding: 24px;
    }

    /* ===== Reset & Base ===== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font-sans);
      font-size: 15px;
      line-height: 1.55;
      color: var(--ink);
      background: var(--canvas);
      -webkit-font-smoothing: antialiased;
    }

    /* ===== Layout ===== */
    article {
      max-width: var(--content-width);
      margin: 0 auto;
      background: var(--paper);
      min-height: 100vh;
      padding: 0 48px 80px;
    }

    /* ===== Header ===== */
    header {
      padding: 56px 0 40px;
      border-bottom: 1.5px solid var(--line);
      margin-bottom: var(--section-gap);
    }
    .eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--ink-subtle);
      margin-bottom: 20px;
    }
    header h1 {
      font-family: var(--font-serif);
      font-size: 40px;
      font-weight: 600;
      line-height: 1.15;
      color: var(--ink);
      margin-bottom: 16px;
    }
    header .subtitle {
      font-size: 18px;
      line-height: 1.45;
      color: var(--ink-subtle);
      max-width: 640px;
    }

    /* ===== Sections ===== */
    section {
      margin-bottom: var(--section-gap);
    }
    section h2 {
      font-family: var(--font-serif);
      font-size: 22px;
      font-weight: 600;
      color: var(--ink);
      margin-bottom: 20px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--line);
    }
    section p {
      margin-bottom: 14px;
      color: var(--ink);
      line-height: 1.6;
    }
    section p:last-child { margin-bottom: 0; }

    /* ===== Cards ===== */
    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
      margin-top: 20px;
    }
    .fact-card {
      padding: var(--card-padding);
      background: var(--canvas);
      border-radius: 8px;
      border: 1px solid var(--line);
    }
    .fact-card .label {
      font-size: 11px;
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--ink-subtle);
      margin-bottom: 8px;
    }
    .fact-card .value {
      font-family: var(--font-sans);
      font-size: 24px;
      font-weight: 600;
      color: var(--ink);
      line-height: 1.2;
    }
    .fact-card .unit {
      font-size: 12px;
      color: var(--ink-subtle);
      margin-top: 4px;
    }

    /* ===== Lists ===== */
    .bullet-list, .driver-list, .checklist {
      list-style: none;
      margin-top: 16px;
    }
    .bullet-list li, .driver-list li, .checklist li {
      position: relative;
      padding-left: 24px;
      margin-bottom: 10px;
      font-size: 14px;
      line-height: 1.5;
    }
    .bullet-list li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 8px;
      width: 6px;
      height: 6px;
      background: var(--accent);
      border-radius: 50%;
    }
    .driver-list li::before {
      content: "→";
      position: absolute;
      left: 0;
      color: var(--brand);
      font-weight: 600;
    }
    .checklist li::before {
      content: "✓";
      position: absolute;
      left: 0;
      color: var(--success);
      font-weight: 600;
    }

    /* ===== Tables ===== */
    .data-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
      font-size: 14px;
    }
    .data-table th {
      text-align: left;
      padding: 12px 16px;
      font-weight: 500;
      color: var(--ink-subtle);
      border-bottom: 1.5px solid var(--line);
      font-family: var(--font-mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }
    .data-table td {
      padding: 12px 16px;
      border-bottom: 1px solid var(--line);
      color: var(--ink);
    }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:hover td { background: var(--canvas); }

    /* ===== Callouts ===== */
    .insight-callout {
      margin-top: 20px;
      padding: 16px 20px;
      background: var(--accent-muted);
      border-left: 3px solid var(--accent);
      border-radius: 0 6px 6px 0;
      font-size: 14px;
      line-height: 1.5;
      color: var(--ink);
    }
    .insight-callout::before {
      content: "Insight";
      display: block;
      font-family: var(--font-mono);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--accent);
      margin-bottom: 6px;
    }
    .summary-strip {
      margin-top: 24px;
      padding: 20px 24px;
      background: var(--canvas);
      border-left: 3px solid var(--brand);
      border-radius: 0 6px 6px 0;
    }
    .summary-strip ul { list-style: none; }
    .summary-strip li {
      position: relative;
      padding-left: 20px;
      margin-bottom: 8px;
      font-size: 14px;
      line-height: 1.5;
      color: var(--ink);
    }
    .summary-strip li:last-child { margin-bottom: 0; }
    .summary-strip li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 8px;
      width: 6px;
      height: 6px;
      background: var(--accent);
      border-radius: 50%;
    }

    /* ===== Badges ===== */
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      margin-top: 24px;
      padding: 10px 20px;
      background: var(--brand-muted);
      border-radius: 6px;
      font-size: 14px;
    }
    .badge .label { font-weight: 600; color: var(--brand); }
    .badge .value { color: var(--ink-subtle); font-family: var(--font-mono); }

    /* ===== Risk / Catalyst ===== */
    .risk-grid, .catalyst-grid, .case-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 16px;
      margin-top: 20px;
    }
    .risk-card, .catalyst-card, .case-card {
      padding: var(--card-padding);
      background: var(--canvas);
      border-radius: 8px;
      border: 1px solid var(--line);
    }
    .risk-card .severity {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 10px;
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-bottom: 8px;
    }
    .severity-high { background: #F2D9D9; color: var(--danger); }
    .severity-medium { background: #F2EBD9; color: var(--warning); }
    .severity-low { background: #D9F2E5; color: var(--success); }
    .risk-card h4, .catalyst-card h4, .case-card h4 {
      font-size: 15px;
      font-weight: 600;
      margin-bottom: 6px;
      color: var(--ink);
    }
    .risk-card p, .catalyst-card p, .case-card p {
      font-size: 13px;
      color: var(--ink-subtle);
      line-height: 1.5;
      margin: 0;
    }
    .catalyst-card .timeline {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--brand);
      margin-top: 8px;
    }

    /* ===== Steps / Timeline ===== */
    .step-list {
      list-style: none;
      counter-reset: step;
      margin-top: 20px;
    }
    .step-list li {
      position: relative;
      padding-left: 48px;
      margin-bottom: 24px;
      min-height: 36px;
    }
    .step-list li::before {
      counter-increment: step;
      content: counter(step);
      position: absolute;
      left: 0;
      top: 0;
      width: 32px;
      height: 32px;
      background: var(--brand);
      color: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-mono);
      font-size: 14px;
      font-weight: 600;
    }
    .step-list .step-title {
      font-weight: 600;
      font-size: 15px;
      margin-bottom: 4px;
    }
    .step-list .step-desc {
      font-size: 13px;
      color: var(--ink-subtle);
    }
    .step-list .step-owner {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--brand);
      margin-top: 4px;
    }

    .timeline-list {
      list-style: none;
      position: relative;
      padding-left: 24px;
      margin-top: 20px;
    }
    .timeline-list::before {
      content: "";
      position: absolute;
      left: 6px;
      top: 4px;
      bottom: 4px;
      width: 2px;
      background: var(--line);
    }
    .timeline-list li {
      position: relative;
      padding-left: 28px;
      margin-bottom: 24px;
    }
    .timeline-list li::before {
      content: "";
      position: absolute;
      left: -20px;
      top: 6px;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--brand);
      border: 2px solid var(--paper);
    }
    .timeline-list .tl-date {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--brand);
      margin-bottom: 4px;
    }
    .timeline-list .tl-title {
      font-weight: 600;
      font-size: 15px;
      margin-bottom: 4px;
    }
    .timeline-list .tl-desc {
      font-size: 13px;
      color: var(--ink-subtle);
    }
    .timeline-list li.status-completed::before { background: var(--success); }
    .timeline-list li.status-in_progress::before { background: var(--warning); }
    .timeline-list li.status-upcoming::before { background: var(--line); }

    /* ===== Footer / Disclosure ===== */
    .disclosure {
      margin-top: var(--section-gap);
      padding-top: 32px;
      border-top: 1.5px solid var(--line);
    }
    .disclosure h3 {
      font-family: var(--font-serif);
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 12px;
      color: var(--ink);
    }
    .disclosure p {
      font-size: 12px;
      line-height: 1.6;
      color: var(--ink-subtle);
    }
    .footer-meta {
      margin-top: 32px;
      padding-top: 20px;
      border-top: 1px solid var(--line);
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--ink-subtle);
      display: flex;
      justify-content: space-between;
    }

    /* ===== Charts ===== */
    .chart-container {
      margin-top: 24px;
      padding: 16px;
      background: var(--canvas);
      border-radius: 8px;
      border: 1px solid var(--line);
    }
    .chart-container svg {
      display: block;
      width: 100%;
    }

    /* ===== Code Blocks ===== */
    .code-block {
      margin-top: 20px;
      margin-bottom: 20px;
      background: var(--canvas);
      border: 1px solid var(--line);
      border-radius: 8px;
      overflow: hidden;
    }
    .code-block .code-label {
      padding: 8px 16px;
      font-family: var(--font-mono);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--ink-subtle);
      border-bottom: 1px solid var(--line);
      background: rgba(0,0,0,0.03);
    }
    .code-block pre {
      margin: 0;
      padding: 20px 24px;
      overflow-x: auto;
      font-family: var(--font-mono);
      font-size: 13px;
      line-height: 1.6;
      color: var(--ink);
      white-space: pre;
    }
    .code-block code {
      font-family: var(--font-mono);
      font-size: 13px;
    }

    /* ===== Print Safety ===== */
    @media print {
      body { background: #fff; }
      article { padding: 0 32px; max-width: 100%; }
      section { break-inside: avoid; page-break-inside: avoid; }
      header { break-after: avoid; page-break-after: avoid; }
      .card-grid, .case-grid, .risk-grid, .kpi-row { break-inside: avoid; }
    }
  </style>
  {% block extra_css %}{% endblock %}
</head>
<body>
  <article data-document-type="{{ document_type }}">
    {% block content %}{% endblock %}
    {% block footer %}{% endblock %}
  </article>
</body>
</html>
