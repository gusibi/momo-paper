{% extends "_base.html.j2" %}
{% block title %}Momo Paper · Timeline · {{ meta.title }}{% endblock %}
{% block content %}
  <header class="mb-[var(--space-3xl)] text-left">
    <p class="eyebrow block mb-[var(--space-sm)] font-mono text-[0.75rem] font-medium uppercase tracking-[0.08em] text-brand">{{ meta.eyebrow | default('Momo Paper / timeline / ' + locale) }}</p>
    <h1>{{ meta.title }}</h1>
    <p class="subtitle max-w-full text-[1.1rem] text-subtle md:max-w-[var(--max-width-text)]">{{ meta.subtitle }}</p>
  </header>

  {% if sections.milestones %}
  <section>
    <h2>{% if locale == 'zh-CN' %}里程碑{% else %}Milestones{% endif %}</h2>
    <ul class="timeline-list">
      {% for ms in sections.milestones %}
      <li class="status-{{ ms.status | default('upcoming') }}">
        <div class="tl-date">{{ ms.date }}</div>
        <div class="tl-title">{{ ms.title }}</div>
        <div class="tl-desc">{{ ms.description }}</div>
      </li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  {% if sections.phases %}
  <section>
    <h2>{% if locale == 'zh-CN' %}阶段说明{% else %}Phases{% endif %}</h2>
    {% for phase in sections.phases %}
    <div class="case-card mb-md">
      <h4>{{ phase.name }}{% if phase.period %} <span class="text-sm" style="font-family: var(--font-mono); color: var(--ink-subtle);">({{ phase.period }})</span>{% endif %}</h4>
      <p>{{ phase.description }}</p>
    </div>
    {% endfor %}
  </section>
  {% endif %}

  {% if sections.next_steps %}
  <section>
    <h2>{% if locale == 'zh-CN' %}下一步{% else %}Next Steps{% endif %}</h2>
    {% for para in sections.next_steps.body %}
    <p>{{ para }}</p>
    {% endfor %}
  </section>
  {% endif %}
{% endblock %}
