{% extends "_base.html.j2" %}
{% block title %}Momo Paper · Stats Report · {{ meta.title }}{% endblock %}
  {% block extra_css %}
  <style>
    .kpi-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: var(--space-lg);
      margin-top: var(--space-xl);
    }
    .kpi-card {
      padding: var(--card-padding);
      background: var(--canvas);
      border-radius: var(--radius-md);
      border: var(--border-thin) solid var(--line);
      text-align: center;
    }
    .kpi-card .kpi-value {
      font-size: var(--title-md);
      font-weight: var(--font-semibold);
      color: var(--ink);
      line-height: 1.2;
    }
    .kpi-card .kpi-label {
      font-size: var(--caption);
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: var(--letter-spacing-wide);
      color: var(--ink-subtle);
      margin-top: var(--space-sm);
    }
    .kpi-card .kpi-change {
      font-size: var(--body-sm);
      margin-top: var(--space-xs);
    }
    .kpi-change.up { color: var(--success); }
    .kpi-change.down { color: var(--danger); }
    .kpi-change.flat { color: var(--ink-subtle); }
    .anomaly-alert {
      margin-top: var(--space-xl);
      padding: var(--space-lg) var(--space-xl);
      background: #F2D9D9;
      border-left: var(--border-medium) solid var(--danger);
      border-radius: 0 var(--radius-md) var(--radius-md) 0;
      font-size: var(--body-md);
    }
    .anomaly-alert::before {
      content: "Anomaly";
      display: block;
      font-family: var(--font-mono);
      font-size: var(--caption);
      text-transform: uppercase;
      letter-spacing: var(--letter-spacing-wide);
      color: var(--danger);
      margin-bottom: var(--space-sm);
    }
    .section-item { margin-bottom: var(--space-xl); }
    .section-subtitle { font-size: 1rem; font-weight: 600; margin-bottom: var(--space-sm); }
    .chart-mt { margin-top: var(--space-md); }
    .diagram-container-styled {
      background: var(--bg-secondary);
      padding: var(--space-2xl);
      border-radius: var(--radius);
      border: 1px solid var(--border-light);
    }
    .mt-0 { margin-top: 0 !important; }
  </style>
  {% endblock %}
{% block content %}
  <header class="mb-[var(--space-3xl)] text-left">
    <p class="eyebrow block mb-[var(--space-sm)] font-mono text-[0.75rem] font-medium uppercase tracking-[0.08em] text-brand">{{ meta.eyebrow | default('Momo Paper / stats_report / ' + locale) }}</p>
    <h1>{{ meta.title }}</h1>
    <p class="subtitle max-w-full text-[1.1rem] text-subtle md:max-w-[var(--max-width-text)]">{{ meta.subtitle }}</p>
  </header>

  {% if sections.kpis %}
  <section>
    <h2>{% if locale == 'zh-CN' %}KPI{% else %}KPIs{% endif %}</h2>
    <div class="kpi-row">
      {% for kpi in sections.kpis %}
      <div class="kpi-card">
        <div class="kpi-value">{{ kpi.value }}</div>
        <div class="kpi-label">{{ kpi.label }}</div>
        {% if kpi.change %}<div class="kpi-change {{ kpi.trend | default('flat') }}">{{ kpi.change }}</div>{% endif %}
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {% if sections.trends %}
  <section>
    <h2>{% if locale == 'zh-CN' %}趋势{% else %}Trends{% endif %}</h2>
    {% for para in sections.trends.body %}
    <p>{{ para }}</p>
    {% endfor %}
    {% if sections.trends.chart %}
    <div class="chart-container">
      {{ sections.trends.chart | render_chart }}
    </div>
    {% endif %}
    {% if sections.trends.anomalies %}
    <div class="anomaly-alert">
      <ul class="bullet-list mt-0">
        {% for a in sections.trends.anomalies %}
        <li>{{ a }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </section>
  {% endif %}

  {% if sections.segments %}
  <section>
    <h2>{% if locale == 'zh-CN' %}分布与分群{% else %}Segments{% endif %}</h2>
    {% for seg in sections.segments %}
    <div class="section-item">
      <h4 class="section-subtitle">{{ seg.name }}</h4>
      {% for para in seg.body %}
      <p>{{ para }}</p>
      {% endfor %}
      {% if seg.chart %}
      <div class="chart-container chart-mt">
        {{ seg.chart | render_chart }}
      </div>
      {% endif %}
    </div>
    {% endfor %}
  </section>
  {% endif %}

  {% if sections.diagrams %}
  <section>
    <h2>{% if locale == 'zh-CN' %}图示原语{% else %}Diagram Primitives{% endif %}</h2>
    {% for item in sections.diagrams %}
    <div class="section-item">
      <h4 class="section-subtitle">{{ item.name }}</h4>
      {% for para in item.body %}
      <p>{{ para }}</p>
      {% endfor %}
      {% if item.diagram %}
      <div class="diagram-container diagram-container-styled">
        {{ item.diagram | render_diagram }}
      </div>
      {% endif %}
    </div>
    {% endfor %}
  </section>
  {% endif %}

  {% if sections.method %}
  <section>
    <h2>{% if locale == 'zh-CN' %}方法说明{% else %}Methodology{% endif %}</h2>
    {% for para in sections.method.body %}
    <p>{{ para }}</p>
    {% endfor %}
  </section>
  {% endif %}
{% endblock %}
{% block footer %}
  <div class="footer-meta">
    <span>{{ meta.period | default('') }}</span>
    <span></span>
  </div>
{% endblock %}
