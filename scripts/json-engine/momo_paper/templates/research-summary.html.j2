{% extends "_base.html.j2" %}
{% block title %}Momo Paper · Research Summary · {{ meta.title }}{% endblock %}
{% block content %}
  <header class="mb-[var(--space-3xl)] text-left">
    <p class="eyebrow block mb-[var(--space-sm)] font-mono text-[0.75rem] font-medium uppercase tracking-[0.08em] text-brand">{{ meta.eyebrow | default('Momo Paper / research_summary / ' + locale) }}</p>
    <h1>{{ meta.title }}</h1>
    <p class="subtitle max-w-full text-[1.1rem] text-subtle md:max-w-[var(--max-width-text)]">{{ meta.subtitle }}</p>
  </header>

  {% if sections.thesis %}
  <section>
    <h2>{% if locale == 'zh-CN' %}核心论点{% else %}Thesis{% endif %}</h2>
    {% for para in sections.thesis.body %}
    <p>{{ para }}</p>
    {% endfor %}
  </section>
  {% endif %}

  {% if sections.key_findings %}
  <section>
    <h2>{% if locale == 'zh-CN' %}关键发现{% else %}Key Findings{% endif %}</h2>
    {% for finding in sections.key_findings %}
    <div class="case-card mb-md">
      <h4>{{ finding.title }}</h4>
      <p>{{ finding.description }}</p>
      {% if finding.evidence %}<p class="text-sm" style="color: var(--ink-subtle); margin-top: var(--space-xs);"><strong>{% if locale == 'zh-CN' %}证据：{% else %}Evidence: {% endif %}</strong>{{ finding.evidence }}</p>{% endif %}
    </div>
    {% endfor %}
  </section>
  {% endif %}

  {% if sections.implications %}
  <section>
    <h2>{% if locale == 'zh-CN' %}含义{% else %}Implications{% endif %}</h2>
    {% for para in sections.implications.body %}
    <p>{{ para }}</p>
    {% endfor %}
  </section>
  {% endif %}

  {% if sections.method %}
  <section>
    <h2>{% if locale == 'zh-CN' %}方法{% else %}Method{% endif %}</h2>
    {% for para in sections.method.body %}
    <p>{{ para }}</p>
    {% endfor %}
    {% if sections.method.sources %}
    <p style="font-family: var(--font-mono); font-size: 12px; color: var(--ink-subtle); margin-top: 12px;">
      <strong>{% if locale == 'zh-CN' %}来源：{% else %}Sources: {% endif %}</strong>{{ sections.method.sources | join(' | ') }}
    </p>
    {% endif %}
  </section>
  {% endif %}
{% endblock %}
