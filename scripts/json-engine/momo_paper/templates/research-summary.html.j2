{% extends "_base.html.j2" %}
{% block title %}Momo Paper · Research Summary · {{ meta.title }}{% endblock %}
{% block content %}
  <header class="mb-[var(--space-3xl)] text-left">
    <p class="block mb-[var(--space-sm)] font-mono text-[0.75rem] font-medium uppercase tracking-[0.08em] text-brand">{{ meta.eyebrow | default('Momo Paper / research_summary / ' + locale) }}</p>
    <h1>{{ meta.title }}</h1>
    <p class="max-w-full text-[1.1rem] text-subtle md:max-w-[var(--max-width-text)]">{{ meta.subtitle }}</p>
  </header>

  {% if sections.thesis %}
  <section>
    <h2>{% if locale == 'zh-CN' %}核心论点{% else %}Thesis{% endif %}</h2>
    {% for para in sections.thesis.body %}
    <p>{{ para }}</p>
    {% endfor %}
  </section>
  {% endif %}

  {% if sections.key_findings %}
  <section>
    <h2>{% if locale == 'zh-CN' %}关键发现{% else %}Key Findings{% endif %}</h2>
    {% for finding in sections.key_findings %}
    <div class="relative mb-4 overflow-hidden rounded-[var(--radius)] border border-[var(--border-light)] bg-surface3 p-[var(--space-xl)] transition-all duration-350 hover:-translate-y-0.5 hover:border-[var(--border)] hover:shadow-[var(--shadow)] before:absolute before:inset-0 before:rounded-[var(--radius)] before:bg-gradient-to-b before:from-white/[0.015] before:to-transparent before:pointer-events-none before:hover:bg-gradient-to-r before:hover:from-brand before:hover:to-transparent before:hover:opacity-0 before:hover:content-['']">
      <h4 class="relative z-[1] mb-[var(--space-sm)] font-display text-[1.1rem] font-semibold text-[var(--text-heading)]">{{ finding.title }}</h4>
      <p class="relative z-[1] mb-0 text-[0.9rem] leading-[1.6] text-subtle">{{ finding.description }}</p>
      {% if finding.evidence %}<p class="relative z-[1] mt-[var(--space-xs)] text-[13px] text-subtle"><strong>{% if locale == 'zh-CN' %}证据：{% else %}Evidence: {% endif %}</strong>{{ finding.evidence }}</p>{% endif %}
    </div>
    {% endfor %}
  </section>
  {% endif %}

  {% if sections.implications %}
  <section>
    <h2>{% if locale == 'zh-CN' %}含义{% else %}Implications{% endif %}</h2>
    {% for para in sections.implications.body %}
    <p>{{ para }}</p>
    {% endfor %}
  </section>
  {% endif %}

  {% if sections.method %}
  <section>
    <h2>{% if locale == 'zh-CN' %}方法{% else %}Method{% endif %}</h2>
    {% for para in sections.method.body %}
    <p>{{ para }}</p>
    {% endfor %}
    {% if sections.method.sources %}
    <p class="mt-3 font-mono text-[12px] text-subtle">
      <strong>{% if locale == 'zh-CN' %}来源：{% else %}Sources: {% endif %}</strong>{{ sections.method.sources | join(' | ') }}
    </p>
    {% endif %}
  </section>
  {% endif %}
{% endblock %}
