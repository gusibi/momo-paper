{% extends "_base.html.j2" %}
{% block title %}Momo Paper · Process Flow · {{ meta.title }}{% endblock %}
{% block content %}
  <header class="mb-[var(--space-3xl)] text-left">
    <p class="block mb-[var(--space-sm)] font-mono text-[0.75rem] font-medium uppercase tracking-[0.08em] text-brand">{{ meta.eyebrow | default('Momo Paper / process_flow / ' + locale) }}</p>
    <h1>{{ meta.title }}</h1>
    <p class="max-w-full text-[1.1rem] text-subtle md:max-w-[var(--max-width-text)]">{{ meta.subtitle }}</p>
  </header>

  {% if sections.lead %}
  <section>
    <h2>{% if locale == 'zh-CN' %}概述{% else %}Overview{% endif %}</h2>
    {% for para in sections.lead.body %}
    <p>{{ para }}</p>
    {% endfor %}
  </section>
  {% endif %}

  {% if sections.flow %}
  <section>
    <h2>{% if locale == 'zh-CN' %}主流程{% else %}Core Flow{% endif %}</h2>
    <ol class="step-list">
      {% for step in sections.flow.steps %}
      <li>
        <div class="font-semibold text-[1.05rem] text-[var(--text-heading)] mb-[var(--space-xs)]">{{ step.title }}</div>
        <div class="text-[0.9rem] leading-[1.6] text-subtle">{{ step.description }}</div>
        {% if step.owner %}<div class="mt-[var(--space-xs)] font-mono text-[0.75rem] text-brand">{{ step.owner }}</div>{% endif %}
      </li>
      {% endfor %}
    </ol>
  </section>
  {% endif %}

  {% if sections.branches %}
  <section>
    <h2>{% if locale == 'zh-CN' %}分支与例外{% else %}Branches & Exceptions{% endif %}</h2>
    {% for para in sections.branches.body %}
    <p>{{ para }}</p>
    {% endfor %}
    {% if sections.branches.conditions %}
    <ul class="my-[var(--space-md)] list-none pl-0">
      {% for cond in sections.branches.conditions %}
      <li class="relative mb-[var(--space-sm)] pl-[var(--space-xl)] text-[0.95rem] leading-[1.6] text-subtle before:absolute before:left-[4px] before:top-[10px] before:h-[6px] before:w-[6px] before:rounded-full before:bg-[var(--accent-2)] before:content-['']">{{ cond }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </section>
  {% endif %}

  {% if sections.takeaways %}
  <section>
    <h2>{% if locale == 'zh-CN' %}执行要点{% else %}Takeaways{% endif %}</h2>
    {% for para in sections.takeaways.body %}
    <p>{{ para }}</p>
    {% endfor %}
    {% if sections.takeaways.checklist %}
    <ul class="my-[var(--space-md)] list-none pl-0">
      {% for item in sections.takeaways.checklist %}
      <li class="relative mb-[var(--space-sm)] pl-[var(--space-xl)] text-[0.95rem] leading-[1.6] text-subtle before:absolute before:left-0 before:font-bold before:text-[var(--green)] before:content-['✓']">{{ item }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </section>
  {% endif %}
{% endblock %}
