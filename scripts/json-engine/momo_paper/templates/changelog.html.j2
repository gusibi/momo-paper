{% extends "_base.html.j2" %}
{% block title %}Momo Paper · Changelog · {{ meta.title }}{% endblock %}
{% block extra_css %}
  <style>
    .changelog-category h3 {
      font-family: var(--font-mono);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--ink-subtle);
      margin-bottom: 12px;
      padding-bottom: 6px;
      border-bottom: 1px solid var(--line);
    }
  </style>
{% endblock %}
{% block content %}
  <header class="mb-[var(--space-3xl)] text-left">
    <p class="block mb-[var(--space-sm)] font-mono text-[0.75rem] font-medium uppercase tracking-[0.08em] text-brand">{{ meta.eyebrow | default('Momo Paper / changelog / ' + locale) }}</p>
    <h1>{{ meta.title }}</h1>
    <p class="max-w-full text-[1.1rem] text-subtle md:max-w-[var(--max-width-text)]">{{ meta.subtitle }}</p>
  </header>

  {% if sections.highlights %}
  <section>
    <h2>{% if locale == 'zh-CN' %}Highlights{% else %}Highlights{% endif %}</h2>
    <ul class="my-[var(--space-xl)] list-none rounded-[0_var(--radius)_var(--radius)_0] border-l-[3px] border-l-brand bg-surface2 p-[var(--space-lg)_var(--space-xl)] pl-0">
      {% for item in sections.highlights['items'] %}
      <li class="relative mb-[var(--space-sm)] pl-[var(--space-xl)] text-[0.95rem] leading-[1.6] text-ink before:absolute before:left-[4px] before:top-[10px] before:h-[6px] before:w-[6px] before:rounded-full before:bg-[var(--accent-2)] before:content-[''] last:mb-0">{{ item }}</li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  {% for cat in sections.changes %}
  <div class="mb-6">
    <h3 class="{% if cat.category == 'added' %}!text-[var(--success)]{% elif cat.category == 'changed' %}!text-[var(--warning)]{% elif cat.category == 'fixed' %}!text-brand{% elif cat.category == 'removed' or cat.category == 'security' %}!text-[var(--danger)]{% endif %}">{{ cat.category }}</h3>
    <ul class="list-none pl-0">
      {% for item in cat['items'] %}
      <li class="relative mb-2 pl-5 text-[14px] before:absolute before:left-0 before:text-brand before:content-['•']">{{ item }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}

  {% if sections.migration %}
  <section>
    <h2>{% if locale == 'zh-CN' %}Migration Notes{% else %}Migration Notes{% endif %}</h2>
    {% for para in sections.migration.body %}
    <p>{{ para }}</p>
    {% endfor %}
  </section>
  {% endif %}
{% endblock %}
{% block footer %}
  <div class="mt-[var(--space-2xl)] flex flex-wrap justify-between gap-[var(--space-sm)] border-t border-[var(--border-light)] pt-[var(--space-lg)] font-mono text-[0.75rem] text-[var(--text-muted)] max-md:flex-col">
    <span>{{ meta.version | default('') }}</span>
    <span>{{ meta.date | default('') }}</span>
  </div>
{% endblock %}
