{% extends "_base.html.j2" %}
{% block title %}Momo Paper · Infographic · {{ meta.title }}{% endblock %}
  {% block extra_css %}
  <style>
    .metric-cluster {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin: 24px 0;
    }
    .metric-block {
      text-align: center;
      padding: 32px 24px;
      background: var(--canvas);
      border-radius: 8px;
      border: 1px solid var(--line);
    }
    .metric-block .metric-number {
      font-size: 48px;
      font-weight: 700;
      color: var(--brand);
      line-height: 1.1;
      font-family: var(--font-sans);
    }
    .metric-block .metric-unit {
      font-size: 14px;
      color: var(--ink-subtle);
      margin-top: 4px;
    }
    .metric-block .metric-label {
      font-size: 12px;
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--ink-subtle);
      margin-top: 12px;
    }
    .text-body-lg { font-size: 1rem; line-height: 1.6; }
  </style>
  {% endblock %}
{% block content %}
  <header>
    <p class="eyebrow">{{ meta.eyebrow | default('Momo Paper / infographic / ' + locale) }}</p>
    <h1>{{ meta.title }}</h1>
    <p class="subtitle">{{ meta.subtitle }}</p>
  </header>

  {% if sections.headline %}
  <section>
    {% for para in sections.headline.body %}
    <p class="text-body-lg">{{ para }}</p>
    {% endfor %}
  </section>
  {% endif %}

  {% if sections.metrics %}
  <section>
    <div class="metric-cluster">
      {% for m in sections.metrics %}
      <div class="metric-block">
        <div class="metric-number">{{ m.value }}</div>
        {% if m.unit %}<div class="metric-unit">{{ m.unit }}</div>{% endif %}
        <div class="metric-label">{{ m.label }}</div>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {% if sections.core_path %}
  <section>
    <h2>{% if locale == 'zh-CN' %}核心路径{% else %}Core Path{% endif %}</h2>
    {% for para in sections.core_path.body %}
    <p>{{ para }}</p>
    {% endfor %}
    {% if sections.core_path.steps %}
    <ol class="step-list">
      {% for step in sections.core_path.steps %}
      <li>
        <div class="step-title">{{ step }}</div>
      </li>
      {% endfor %}
    </ol>
    {% endif %}
  </section>
  {% endif %}

  {% if sections.distribution %}
  <section>
    <h2>{% if locale == 'zh-CN' %}分布{% else %}Distribution{% endif %}</h2>
    {% if sections.distribution.chart %}
    <div class="chart-container">
      {{ sections.distribution.chart | render_chart }}
    </div>
    {% endif %}
  </section>
  {% endif %}

  {% if sections.takeaway %}
  <section>
    <h2>{% if locale == 'zh-CN' %}结论{% else %}Takeaway{% endif %}</h2>
    {% for para in sections.takeaway.body %}
    <p>{{ para }}</p>
    {% endfor %}
  </section>
  {% endif %}
{% endblock %}
