{% extends "_base.html.j2" %}
{% block title %}Momo Paper · Infographic · {{ meta.title }}{% endblock %}
{% block extra_css %}
  <style>
    .card-surface {
      background: var(--paper);
      border: 1px solid var(--line);
      box-shadow: var(--shadow-soft);
    }
    .card-surface:hover {
      border-color: var(--brand);
      box-shadow: var(--shadow-surface);
    }
    .chart-surface {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow-soft);
    }
  </style>
{% endblock %}
{% block content %}
  <header class="mb-[var(--space-3xl)] text-left">
    <p class="block mb-[var(--space-sm)] font-mono text-[0.75rem] font-medium uppercase tracking-[0.08em] text-brand">{{ meta.eyebrow | default('Momo Paper / infographic / ' + locale) }}</p>
    <h1>{{ meta.title }}</h1>
    <p class="max-w-full text-[1.1rem] text-subtle md:max-w-[var(--max-width-text)]">{{ meta.subtitle }}</p>
  </header>

  {% if sections.headline %}
  <section>
    {% for para in sections.headline.body %}
    <p class="text-[1rem] leading-[1.6]">{{ para }}</p>
    {% endfor %}
  </section>
  {% endif %}

  {% if sections.metrics %}
  <section>
    <div class="my-6 grid grid-cols-[repeat(auto-fit,minmax(200px,1fr))] gap-5">
      {% for m in sections.metrics %}
      <div class="card-surface rounded-lg px-6 py-8 text-center">
        <div class="font-sans text-[48px] font-bold leading-[1.1] text-brand">{{ m.value }}</div>
        {% if m.unit %}<div class="mt-1 text-[14px] text-subtle">{{ m.unit }}</div>{% endif %}
        <div class="mt-3 font-mono text-[12px] uppercase tracking-[0.04em] text-subtle">{{ m.label }}</div>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {% if sections.core_path %}
  <section>
    <h2>{% if locale == 'zh-CN' %}核心路径{% else %}Core Path{% endif %}</h2>
    {% for para in sections.core_path.body %}
    <p>{{ para }}</p>
    {% endfor %}
    {% if sections.core_path.steps %}
    <ol class="step-list">
      {% for step in sections.core_path.steps %}
      <li>
        <div class="font-semibold text-[1.05rem] text-[var(--text-heading)] mb-[var(--space-xs)]">{{ step }}</div>
      </li>
      {% endfor %}
    </ol>
    {% endif %}
  </section>
  {% endif %}

  {% if sections.distribution %}
  <section>
    <h2>{% if locale == 'zh-CN' %}分布{% else %}Distribution{% endif %}</h2>
    {% if sections.distribution.chart %}
    <div class="chart-surface my-[var(--space-xl)] p-[var(--space-lg)] [&_svg]:block [&_svg]:w-full">
      {{ sections.distribution.chart | render_chart }}
    </div>
    {% endif %}
  </section>
  {% endif %}

  {% if sections.takeaway %}
  <section>
    <h2>{% if locale == 'zh-CN' %}结论{% else %}Takeaway{% endif %}</h2>
    {% for para in sections.takeaway.body %}
    <p>{{ para }}</p>
    {% endfor %}
  </section>
  {% endif %}
{% endblock %}
