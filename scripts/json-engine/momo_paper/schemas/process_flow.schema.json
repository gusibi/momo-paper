{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Momo Paper · Process Flow",
  "type": "object",
  "required": ["document_type", "locale", "meta", "sections"],
  "properties": {
    "document_type": { "type": "string", "const": "process_flow" },
    "locale": { "type": "string", "enum": ["zh-CN", "en"] },
    "meta": {
      "type": "object",
      "required": ["title", "subtitle"],
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "eyebrow": { "type": "string" }
      }
    },
    "sections": {
      "type": "object",
      "properties": {
        "lead": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } }
          }
        },
        "flow": {
          "type": "object",
          "properties": {
            "steps": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "number": { "type": "integer" },
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "owner": { "type": "string" }
                }
              }
            }
          }
        },
        "branches": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } },
            "conditions": { "type": "array", "items": { "type": "string" } }
          }
        },
        "takeaways": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } },
            "checklist": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
