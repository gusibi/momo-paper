{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Momo Paper · Research Summary",
  "type": "object",
  "required": ["document_type", "locale", "meta", "sections"],
  "properties": {
    "document_type": { "type": "string", "const": "research_summary" },
    "locale": { "type": "string", "enum": ["zh-CN", "en"] },
    "meta": {
      "type": "object",
      "required": ["title", "subtitle"],
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "eyebrow": { "type": "string" }
      }
    },
    "sections": {
      "type": "object",
      "properties": {
        "thesis": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } }
          }
        },
        "key_findings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "evidence": { "type": "string" }
            }
          }
        },
        "implications": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } }
          }
        },
        "method": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } },
            "sources": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
