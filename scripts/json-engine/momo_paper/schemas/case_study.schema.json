{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Momo Paper · Case Study",
  "type": "object",
  "required": ["document_type", "locale", "meta", "sections"],
  "properties": {
    "document_type": { "type": "string", "const": "case_study" },
    "locale": { "type": "string", "enum": ["zh-CN", "en"] },
    "meta": {
      "type": "object",
      "required": ["title", "subtitle"],
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "eyebrow": { "type": "string" }
      }
    },
    "sections": {
      "type": "object",
      "properties": {
        "context": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } }
          }
        },
        "problem": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } },
            "metrics": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "label": { "type": "string" },
                  "value": { "type": "string" }
                }
              }
            }
          }
        },
        "approach": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } },
            "steps": { "type": "array", "items": { "type": "string" } }
          }
        },
        "evidence": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } },
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "label": { "type": "string" },
                  "value": { "type": "string" },
                  "change": { "type": "string" }
                }
              }
            }
          }
        },
        "outcome": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } }
          }
        },
        "takeaway": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } },
            "lessons": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
