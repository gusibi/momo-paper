{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Momo Paper · Long Document",
  "type": "object",
  "required": ["document_type", "locale", "meta", "sections"],
  "properties": {
    "document_type": { "type": "string", "const": "long_doc" },
    "locale": { "type": "string", "enum": ["zh-CN", "en"] },
    "meta": {
      "type": "object",
      "required": ["title", "subtitle"],
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "eyebrow": { "type": "string" },
        "date": { "type": "string" },
        "author": { "type": "string" }
      }
    },
    "sections": {
      "type": "object",
      "properties": {
        "abstract": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } },
            "findings": { "type": "array", "items": { "type": "string" } }
          }
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "heading": { "type": "string" },
              "body": { "type": "array", "items": { "type": "string" } },
              "quote": {
                "type": "object",
                "properties": {
                  "text": { "type": "string" },
                  "source": { "type": "string" }
                }
              }
            }
          }
        },
        "conclusion": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } },
            "next_steps": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
