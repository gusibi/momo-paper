{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Momo Paper · Infographic",
  "type": "object",
  "required": ["document_type", "locale", "meta", "sections"],
  "properties": {
    "document_type": { "type": "string", "const": "infographic" },
    "locale": { "type": "string", "enum": ["zh-CN", "en"] },
    "meta": {
      "type": "object",
      "required": ["title", "subtitle"],
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "eyebrow": { "type": "string" }
      }
    },
    "sections": {
      "type": "object",
      "properties": {
        "headline": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } }
          }
        },
        "core_path": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } },
            "steps": { "type": "array", "items": { "type": "string" } }
          }
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" },
              "unit": { "type": "string" }
            }
          }
        },
        "takeaway": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
