{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Momo Paper · Stats Report",
  "type": "object",
  "required": ["document_type", "locale", "meta", "sections"],
  "properties": {
    "document_type": { "type": "string", "const": "stats_report" },
    "locale": { "type": "string", "enum": ["zh-CN", "en"] },
    "meta": {
      "type": "object",
      "required": ["title", "subtitle"],
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "eyebrow": { "type": "string" },
        "period": { "type": "string" }
      }
    },
    "sections": {
      "type": "object",
      "properties": {
        "kpis": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" },
              "change": { "type": "string" },
              "trend": { "type": "string", "enum": ["up", "down", "flat"] }
            }
          }
        },
        "trends": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } },
            "anomalies": { "type": "array", "items": { "type": "string" } }
          }
        },
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "body": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "method": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
