{% extends "_base.html.j2" %}
{% block title %}Momo Paper · Stats Report · {{ meta.title }}{% endblock %}
{% block content %}
  <header>
    <p class="eyebrow">{{ meta.eyebrow | default('Momo Paper / stats_report / ' + locale) }}</p>
    <h1>{{ meta.title }}</h1>
    <p class="subtitle">{{ meta.subtitle }}</p>
  </header>

  {% if sections.kpis %}
  <section>
    <h2>{% if locale == 'zh-CN' %}KPI{% else %}KPIs{% endif %}</h2>
    <div class="kpi-row">
      {% for kpi in sections.kpis %}
      <div class="kpi-card">
        <div class="kpi-value">{{ kpi.value }}</div>
        <div class="kpi-label">{{ kpi.label }}</div>
        {% if kpi.change %}<div class="kpi-change {{ kpi.trend | default('flat') }}">{{ kpi.change }}</div>{% endif %}
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {% if sections.trends %}
  <section>
    <h2>{% if locale == 'zh-CN' %}趋势{% else %}Trends{% endif %}</h2>
    {% for para in sections.trends.body %}
    <p>{{ para }}</p>
    {% endfor %}
    {% if sections.trends.chart %}
    <div class="chart-container">
      {{ sections.trends.chart | render_chart }}
    </div>
    {% endif %}
    {% if sections.trends.anomalies %}
    <div class="anomaly-alert">
      <ul class="bullet-list" style="margin-top: 0;">
        {% for a in sections.trends.anomalies %}
        <li>{{ a }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </section>
  {% endif %}

  {% if sections.segments %}
  <section>
    <h2>{% if locale == 'zh-CN' %}分布与分群{% else %}Segments{% endif %}</h2>
    {% for seg in sections.segments %}
    <div style="margin-bottom: 24px;">
      <h4 style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">{{ seg.name }}</h4>
      {% for para in seg.body %}
      <p>{{ para }}</p>
      {% endfor %}
    </div>
    {% endfor %}
  </section>
  {% endif %}

  {% if sections.method %}
  <section>
    <h2>{% if locale == 'zh-CN' %}方法说明{% else %}Methodology{% endif %}</h2>
    {% for para in sections.method.body %}
    <p>{{ para }}</p>
    {% endfor %}
  </section>
  {% endif %}
{% endblock %}
{% block footer %}
  <div class="footer-meta">
    <span>{{ meta.period | default('') }}</span>
    <span></span>
  </div>
{% endblock %}
