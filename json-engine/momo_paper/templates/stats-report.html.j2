{% extends "_base.html.j2" %}
{% block title %}Momo Paper · Stats Report · {{ meta.title }}{% endblock %}
{% block extra_css %}
  <style>
    .kpi-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 16px;
      margin-top: 20px;
    }
    .kpi-card {
      padding: var(--card-padding);
      background: var(--canvas);
      border-radius: 8px;
      border: 1px solid var(--line);
      text-align: center;
    }
    .kpi-card .kpi-value {
      font-size: 32px;
      font-weight: 600;
      color: var(--ink);
      line-height: 1.2;
    }
    .kpi-card .kpi-label {
      font-size: 11px;
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--ink-subtle);
      margin-top: 6px;
    }
    .kpi-card .kpi-change {
      font-size: 12px;
      margin-top: 4px;
    }
    .kpi-change.up { color: var(--success); }
    .kpi-change.down { color: var(--danger); }
    .kpi-change.flat { color: var(--ink-subtle); }
    .anomaly-alert {
      margin-top: 20px;
      padding: 16px 20px;
      background: #F2D9D9;
      border-left: 3px solid var(--danger);
      border-radius: 0 6px 6px 0;
      font-size: 14px;
    }
    .anomaly-alert::before {
      content: "Anomaly";
      display: block;
      font-family: var(--font-mono);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--danger);
      margin-bottom: 6px;
    }
  </style>
{% endblock %}
{% block content %}
  <header>
    <p class="eyebrow">{{ meta.eyebrow | default('Momo Paper / stats_report / ' + locale) }}</p>
    <h1>{{ meta.title }}</h1>
    <p class="subtitle">{{ meta.subtitle }}</p>
  </header>

  {% if sections.kpis %}
  <section>
    <h2>{% if locale == 'zh-CN' %}KPI{% else %}KPIs{% endif %}</h2>
    <div class="kpi-row">
      {% for kpi in sections.kpis %}
      <div class="kpi-card">
        <div class="kpi-value">{{ kpi.value }}</div>
        <div class="kpi-label">{{ kpi.label }}</div>
        {% if kpi.change %}<div class="kpi-change {{ kpi.trend | default('flat') }}">{{ kpi.change }}</div>{% endif %}
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {% if sections.trends %}
  <section>
    <h2>{% if locale == 'zh-CN' %}趋势{% else %}Trends{% endif %}</h2>
    {% for para in sections.trends.body %}
    <p>{{ para }}</p>
    {% endfor %}
    {% if sections.trends.chart %}
    <div class="chart-container">
      {{ sections.trends.chart | render_chart }}
    </div>
    {% endif %}
    {% if sections.trends.anomalies %}
    <div class="anomaly-alert">
      <ul class="bullet-list" style="margin-top: 0;">
        {% for a in sections.trends.anomalies %}
        <li>{{ a }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </section>
  {% endif %}

  {% if sections.segments %}
  <section>
    <h2>{% if locale == 'zh-CN' %}分布与分群{% else %}Segments{% endif %}</h2>
    {% for seg in sections.segments %}
    <div style="margin-bottom: 24px;">
      <h4 style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">{{ seg.name }}</h4>
      {% for para in seg.body %}
      <p>{{ para }}</p>
      {% endfor %}
    </div>
    {% endfor %}
  </section>
  {% endif %}

  {% if sections.method %}
  <section>
    <h2>{% if locale == 'zh-CN' %}方法说明{% else %}Methodology{% endif %}</h2>
    {% for para in sections.method.body %}
    <p>{{ para }}</p>
    {% endfor %}
  </section>
  {% endif %}
{% endblock %}
{% block footer %}
  <div class="footer-meta">
    <span>{{ meta.period | default('') }}</span>
    <span></span>
  </div>
{% endblock %}
