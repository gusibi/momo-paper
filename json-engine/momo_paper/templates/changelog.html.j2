{% extends "_base.html.j2" %}
{% block title %}Momo Paper · Changelog · {{ meta.title }}{% endblock %}
{% block extra_css %}
  <style>
    .changelog-category {
      margin-bottom: 24px;
    }
    .changelog-category h3 {
      font-family: var(--font-mono);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--ink-subtle);
      margin-bottom: 12px;
      padding-bottom: 6px;
      border-bottom: 1px solid var(--line);
    }
    .changelog-category ul {
      list-style: none;
      padding-left: 0;
    }
    .changelog-category li {
      position: relative;
      padding-left: 20px;
      margin-bottom: 8px;
      font-size: 14px;
    }
    .changelog-category li::before {
      content: "•";
      position: absolute;
      left: 0;
      color: var(--brand);
    }
    .cat-added h3 { color: var(--success); }
    .cat-changed h3 { color: var(--warning); }
    .cat-fixed h3 { color: var(--brand); }
    .cat-deprecated h3 { color: var(--ink-subtle); }
    .cat-removed h3 { color: var(--danger); }
    .cat-security h3 { color: var(--danger); }
  </style>
{% endblock %}
{% block content %}
  <header>
    <p class="eyebrow">{{ meta.eyebrow | default('Momo Paper / changelog / ' + locale) }}</p>
    <h1>{{ meta.title }}</h1>
    <p class="subtitle">{{ meta.subtitle }}</p>
  </header>

  {% if sections.highlights %}
  <section>
    <h2>{% if locale == 'zh-CN' %}Highlights{% else %}Highlights{% endif %}</h2>
    <ul class="summary-strip">
      {% for item in sections.highlights['items'] %}
      <li>{{ item }}</li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  {% for cat in sections.changes %}
  <div class="changelog-category cat-{{ cat.category }}">
    <h3>{{ cat.category }}</h3>
    <ul>
      {% for item in cat['items'] %}
      <li>{{ item }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}

  {% if sections.migration %}
  <section>
    <h2>{% if locale == 'zh-CN' %}Migration Notes{% else %}Migration Notes{% endif %}</h2>
    {% for para in sections.migration.body %}
    <p>{{ para }}</p>
    {% endfor %}
  </section>
  {% endif %}
{% endblock %}
{% block footer %}
  <div class="footer-meta">
    <span>{{ meta.version | default('') }}</span>
    <span>{{ meta.date | default('') }}</span>
  </div>
{% endblock %}
