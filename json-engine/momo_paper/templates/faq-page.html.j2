{% extends "_base.html.j2" %}
{% block title %}Momo Paper · FAQ · {{ meta.title }}{% endblock %}
{% block extra_css %}
  <style>
    .faq-group {
      margin-bottom: 32px;
    }
    .faq-group h3 {
      font-family: var(--font-serif);
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 16px;
      color: var(--ink);
    }
    .faq-item {
      margin-bottom: 16px;
      padding: 16px 20px;
      background: var(--canvas);
      border-radius: 8px;
      border: 1px solid var(--line);
    }
    .faq-item .question {
      font-weight: 600;
      font-size: 15px;
      margin-bottom: 8px;
      color: var(--ink);
    }
    .faq-item .answer {
      font-size: 14px;
      color: var(--ink-subtle);
      line-height: 1.6;
    }
  </style>
{% endblock %}
{% block content %}
  <header>
    <p class="eyebrow">{{ meta.eyebrow | default('Momo Paper / faq_page / ' + locale) }}</p>
    <h1>{{ meta.title }}</h1>
    <p class="subtitle">{{ meta.subtitle }}</p>
  </header>

  {% if sections.lead %}
  <section>
    {% for para in sections.lead.body %}
    <p>{{ para }}</p>
    {% endfor %}
  </section>
  {% endif %}

  {% for group in sections.groups %}
  <div class="faq-group">
    <h3>{{ group.title }}</h3>
    {% for item in group['items'] %}
    <div class="faq-item">
      <div class="question">{{ item.question }}</div>
      <div class="answer">{{ item.answer }}</div>
    </div>
    {% endfor %}
  </div>
  {% endfor %}

  {% if sections.summary %}
  <section>
    <h2>{% if locale == 'zh-CN' %}最终说明{% else %}Summary{% endif %}</h2>
    {% for para in sections.summary.body %}
    <p>{{ para }}</p>
    {% endfor %}
    {% if sections.summary.next_step %}
    <div class="insight-callout">{{ sections.summary.next_step }}</div>
    {% endif %}
  </section>
  {% endif %}
{% endblock %}
