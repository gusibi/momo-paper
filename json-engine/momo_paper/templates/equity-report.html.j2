{% extends "_base.html.j2" %}
{% block title %}Momo Paper · Equity Report · {{ meta.title }}{% endblock %}
{% block extra_css %}
  <style>
    .thesis-badge {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      margin-top: 24px;
      padding: 10px 20px;
      background: var(--brand-muted);
      border-radius: 6px;
      font-size: 14px;
    }
    .thesis-badge .rating { font-weight: 600; color: var(--brand); }
    .thesis-badge .target { color: var(--ink-subtle); font-family: var(--font-mono); }
  </style>
{% endblock %}
{% block content %}
  <header>
    <p class="eyebrow">{{ meta.eyebrow | default('Momo Paper / equity_report / ' + locale) }}</p>
    <h1>{{ meta.title }}</h1>
    <p class="subtitle">{{ meta.subtitle }}</p>

    {% if sections.thesis %}
      {% if sections.thesis.rating or sections.thesis.target_price %}
      <div class="thesis-badge">
        {% if sections.thesis.rating %}<span class="rating">{{ sections.thesis.rating }}</span>{% endif %}
        {% if sections.thesis.target_price %}<span class="target">{{ sections.thesis.target_price }}</span>{% endif %}
      </div>
      {% endif %}
      {% if sections.thesis.summary_points %}
      <div class="summary-strip">
        <ul>
          {% for point in sections.thesis.summary_points %}
          <li>{{ point }}</li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
    {% endif %}
  </header>

  {% if sections.business_snapshot %}
  <section>
    <h2>{% if locale == 'zh-CN' %}公司概览{% else %}Business Snapshot{% endif %}</h2>
    {% for para in sections.business_snapshot.body %}
    <p>{{ para }}</p>
    {% endfor %}
    {% if sections.business_snapshot.cards %}
    <div class="card-grid">
      {% for card in sections.business_snapshot.cards %}
      <div class="fact-card">
        <div class="label">{{ card.label }}</div>
        <div class="value">{{ card.value }}</div>
        {% if card.unit %}<div class="unit">{{ card.unit }}</div>{% endif %}
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </section>
  {% endif %}

  {% if sections.price_and_drivers %}
  <section>
    <h2>{% if locale == 'zh-CN' %}价格与驱动{% else %}Price and Drivers{% endif %}</h2>
    {% for para in sections.price_and_drivers.body %}
    <p>{{ para }}</p>
    {% endfor %}
    {% if sections.price_and_drivers.chart %}
    <div class="chart-container">
      {{ sections.price_and_drivers.chart | render_chart }}
    </div>
    {% endif %}
    {% if sections.price_and_drivers.drivers %}
    <ul class="driver-list">
      {% for driver in sections.price_and_drivers.drivers %}
      <li>{{ driver }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </section>
  {% endif %}

  {% if sections.valuation %}
  <section>
    <h2>{% if locale == 'zh-CN' %}估值{% else %}Valuation{% endif %}</h2>
    {% for para in sections.valuation.body %}
    <p>{{ para }}</p>
    {% endfor %}
    {% if sections.valuation.table %}
    <table class="data-table">
      <thead>
        <tr>
          {% for h in sections.valuation.table.headers %}
          <th>{{ h }}</th>
          {% endfor %}
        </tr>
      </thead>
      <tbody>
        {% for row in sections.valuation.table.rows %}
        <tr>
          {% for cell in row %}
          <td>{{ cell }}</td>
          {% endfor %}
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% endif %}
    {% if sections.valuation.insight %}
    <div class="insight-callout">{{ sections.valuation.insight }}</div>
    {% endif %}
  </section>
  {% endif %}

  {% if sections.risks_and_catalysts %}
  <section>
    <h2>{% if locale == 'zh-CN' %}风险与催化剂{% else %}Risks and Catalysts{% endif %}</h2>
    {% if sections.risks_and_catalysts.risks %}
    <div class="risk-grid">
      {% for risk in sections.risks_and_catalysts.risks %}
      <div class="risk-card">
        {% if risk.severity %}<span class="severity severity-{{ risk.severity }}">{{ risk.severity }}</span>{% endif %}
        <h4>{{ risk.title }}</h4>
        <p>{{ risk.description }}</p>
      </div>
      {% endfor %}
    </div>
    {% endif %}
    {% if sections.risks_and_catalysts.catalysts %}
    <div class="catalyst-grid" style="margin-top: 24px;">
      {% for cat in sections.risks_and_catalysts.catalysts %}
      <div class="catalyst-card">
        <h4>{{ cat.title }}</h4>
        <p>{{ cat.description }}</p>
        {% if cat.timeline %}<div class="timeline">{{ cat.timeline }}</div>{% endif %}
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </section>
  {% endif %}
{% endblock %}
{% block footer %}
  <div class="disclosure">
    <h3>{% if locale == 'zh-CN' %}披露与声明{% else %}Disclosure{% endif %}</h3>
    <p>{{ meta.disclaimer | default('本报告仅供参考，不构成投资建议。投资有风险，入市需谨慎。') }}</p>
  </div>
  <div class="footer-meta">
    <span>{{ meta.date | default('') }}</span>
    <span>{{ meta.analyst | default('') }}</span>
  </div>
{% endblock %}
