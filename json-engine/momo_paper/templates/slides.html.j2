{% extends "_base.html.j2" %}
{% block title %}Momo Paper · Slides · {{ meta.title }}{% endblock %}
{% block extra_css %}
  <style>
    html, body {
      height: 100%;
      overflow: hidden;
      background: #1a1a1a;
    }
    article {
      max-width: 100%;
      padding: 0;
      height: 100vh;
      overflow-y: scroll;
      scroll-snap-type: y mandatory;
      scroll-behavior: smooth;
    }
    .slide {
      width: 100%;
      height: 100vh;
      max-width: 1600px;
      max-height: 900px;
      margin: 0 auto;
      padding: 80px 100px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      scroll-snap-align: start;
      background: var(--paper);
      box-sizing: border-box;
      position: relative;
      page-break-after: always;
    }
    .slide h1 {
      font-family: var(--font-serif);
      font-size: 52px;
      font-weight: 700;
      line-height: 1.2;
      color: var(--ink);
      margin-bottom: 24px;
    }
    .slide h2 {
      font-family: var(--font-serif);
      font-size: 36px;
      font-weight: 600;
      line-height: 1.3;
      color: var(--ink);
      margin-bottom: 32px;
    }
    .slide .point {
      font-size: 24px;
      line-height: 1.5;
      color: var(--ink-subtle);
      margin-bottom: 40px;
      max-width: 900px;
    }
    .slide .bullets {
      list-style: none;
      padding: 0;
      max-width: 900px;
    }
    .slide .bullets li {
      position: relative;
      padding-left: 32px;
      font-size: 22px;
      line-height: 1.7;
      color: var(--ink);
      margin-bottom: 12px;
    }
    .slide .bullets li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 12px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--brand);
    }
    .slide-cover {
      background: var(--brand);
    }
    .slide-cover h1 {
      color: #fff;
      font-size: 64px;
    }
    .slide-cover .subtitle-cover {
      font-size: 24px;
      color: var(--brand-muted);
      margin-top: 16px;
    }
    .slide-cover .eyebrow-cover {
      font-family: var(--font-mono);
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: rgba(255,255,255,0.6);
      margin-bottom: 40px;
    }
    .slide-comparison {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: start;
    }
    .slide-comparison .col h3 {
      font-family: var(--font-serif);
      font-size: 24px;
      font-weight: 600;
      margin-bottom: 16px;
      color: var(--ink);
    }
    .slide-comparison .col p {
      font-size: 18px;
      line-height: 1.6;
      color: var(--ink-subtle);
    }
    .pagination {
      position: absolute;
      bottom: 32px;
      right: 60px;
      font-family: var(--font-mono);
      font-size: 13px;
      color: var(--ink-subtle);
    }
    .slide-note {
      position: absolute;
      bottom: 20px;
      left: 60px;
      font-size: 12px;
      color: var(--ink-subtle);
      opacity: 0.6;
    }

    @media print {
      html, body { height: auto; overflow: visible; background: #fff; }
      article { height: auto; overflow: visible; scroll-snap-type: none; }
      .slide {
        height: auto;
        min-height: 100vh;
        max-height: none;
        page-break-after: always;
        scroll-snap-align: none;
      }
      @page { size: 16in 9in landscape; }
    }
  </style>
{% endblock %}
{% block content %}
  <article data-document-type="slides">
    {% for s in slides %}
    <div class="slide{% if loop.first %} slide-cover{% endif %}{% if s.layout == 'comparison' %} slide-comparison{% endif %}">
      {% if loop.first %}
        <div class="eyebrow-cover">{{ meta.eyebrow | default('Momo Paper / slides') }}</div>
        <h1>{{ meta.title }}</h1>
        {% if meta.subtitle %}<div class="subtitle-cover">{{ meta.subtitle }}</div>{% endif %}
      {% elif s.layout == 'comparison' and s.bullets %}
        <div class="col">
          <h3>{{ s.title }}</h3>
          {% for b in s.bullets[:s.bullets|length // 2 + s.bullets|length % 2] %}
          <p>{{ b }}</p>
          {% endfor %}
        </div>
        <div class="col">
          <h3>{{ s.point }}</h3>
          {% for b in s.bullets[s.bullets|length // 2 + s.bullets|length % 2:] %}
          <p>{{ b }}</p>
          {% endfor %}
        </div>
      {% else %}
        <h2>{{ s.title }}</h2>
        {% if s.point %}<p class="point">{{ s.point }}</p>{% endif %}
        {% if s.bullets %}
        <ul class="bullets">
          {% for b in s.bullets %}
          <li>{{ b }}</li>
          {% endfor %}
        </ul>
        {% endif %}
      {% endif %}
      <div class="pagination">{{ loop.index }} / {{ slides | length }}</div>
      {% if s.note %}<div class="slide-note">{{ s.note }}</div>{% endif %}
    </div>
    {% endfor %}
  </article>
{% endblock %}
