{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Momo Paper · Letter",
  "type": "object",
  "required": ["document_type", "locale", "meta", "sections"],
  "properties": {
    "document_type": { "type": "string", "const": "letter" },
    "locale": { "type": "string", "enum": ["zh-CN", "en"] },
    "meta": {
      "type": "object",
      "required": ["title", "subtitle"],
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "eyebrow": { "type": "string" },
        "date": { "type": "string" },
        "sender": { "type": "string" },
        "recipient": { "type": "string" }
      }
    },
    "sections": {
      "type": "object",
      "properties": {
        "opening": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } }
          }
        },
        "body": {
          "type": "object",
          "properties": {
            "paragraphs": { "type": "array", "items": { "type": "string" } }
          }
        },
        "request": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } },
            "actions": { "type": "array", "items": { "type": "string" } }
          }
        },
        "signoff": {
          "type": "object",
          "properties": {
            "closing": { "type": "string" },
            "name": { "type": "string" },
            "title": { "type": "string" }
          }
        }
      }
    }
  }
}
