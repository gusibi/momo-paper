{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Momo Paper · Equity Report",
  "description": "JSON schema for equity report document generation",
  "type": "object",
  "required": ["document_type", "locale", "meta", "sections"],
  "properties": {
    "document_type": {
      "type": "string",
      "const": "equity_report"
    },
    "locale": {
      "type": "string",
      "enum": ["zh-CN", "en"]
    },
    "meta": {
      "type": "object",
      "required": ["title", "subtitle"],
      "properties": {
        "title": { "type": "string", "description": "标的名称 / Company name" },
        "subtitle": { "type": "string", "description": "投资结论 / Investment thesis" },
        "eyebrow": { "type": "string", "description": "顶部标签，如 Momo Paper / equity_report / zh-CN" },
        "date": { "type": "string", "format": "date" },
        "analyst": { "type": "string" },
        "disclaimer": { "type": "string" }
      }
    },
    "sections": {
      "type": "object",
      "required": ["thesis", "business_snapshot", "price_and_drivers", "valuation", "risks_and_catalysts"],
      "properties": {
        "thesis": {
          "type": "object",
          "properties": {
            "summary_points": {
              "type": "array",
              "items": { "type": "string" },
              "description": "3-5 个核心论点"
            },
            "rating": {
              "type": "string",
              "enum": ["买入", "增持", "持有", "减持", "卖出", "Buy", "Overweight", "Hold", "Underweight", "Sell"]
            },
            "target_price": { "type": "string" }
          }
        },
        "business_snapshot": {
          "type": "object",
          "properties": {
            "body": {
              "type": "array",
              "items": { "type": "string" },
              "description": "段落文本"
            },
            "cards": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "label": { "type": "string" },
                  "value": { "type": "string" },
                  "unit": { "type": "string" }
                }
              },
              "description": "关键数据卡片"
            }
          }
        },
        "price_and_drivers": {
          "type": "object",
          "properties": {
            "body": {
              "type": "array",
              "items": { "type": "string" }
            },
            "chart": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "enum": ["line", "candlestick", "bar"] },
                "title": { "type": "string" },
                "data": { "type": "object" }
              }
            },
            "drivers": {
              "type": "array",
              "items": { "type": "string" },
              "description": "驱动因素列表"
            }
          }
        },
        "valuation": {
          "type": "object",
          "properties": {
            "body": {
              "type": "array",
              "items": { "type": "string" }
            },
            "table": {
              "type": "object",
              "properties": {
                "headers": { "type": "array", "items": { "type": "string" } },
                "rows": { "type": "array", "items": { "type": "array", "items": { "type": "string" } } }
              }
            },
            "insight": { "type": "string", "description": "估值洞察/关键结论" }
          }
        },
        "risks_and_catalysts": {
          "type": "object",
          "properties": {
            "risks": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "severity": { "type": "string", "enum": ["high", "medium", "low"] }
                }
              }
            },
            "catalysts": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "timeline": { "type": "string" }
                }
              }
            }
          }
        },
        "recommendation": {
          "type": "object",
          "properties": {
            "body": { "type": "string" },
            "disclosure": { "type": "string" }
          }
        }
      }
    }
  }
}
