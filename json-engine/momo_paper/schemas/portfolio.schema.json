{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Momo Paper · Portfolio",
  "type": "object",
  "required": ["document_type", "locale", "meta", "sections"],
  "properties": {
    "document_type": { "type": "string", "const": "portfolio" },
    "locale": { "type": "string", "enum": ["zh-CN", "en"] },
    "meta": {
      "type": "object",
      "required": ["title", "subtitle"],
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "eyebrow": { "type": "string" }
      }
    },
    "sections": {
      "type": "object",
      "properties": {
        "overview": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } }
          }
        },
        "cases": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "context": { "type": "string" },
              "action": { "type": "string" },
              "result": { "type": "string" },
              "metrics": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "label": { "type": "string" },
                    "value": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "capabilities": {
          "type": "object",
          "properties": {
            "body": { "type": "array", "items": { "type": "string" } },
            "skills": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
