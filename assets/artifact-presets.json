  "surfaces": {
    "web_dual": {
      "description": "Browser-readable and print-safe document pages.",
      "grid": {
        "canvas": "responsive",
        "maxWidth": 1280,
        "contentWidth": 840,
        "columns": 12,
        "gutter": 24,
        "sectionPaddingY": 64
      },
      "density": "standard",
      "motion": "light",
      "typographyBias": "editorial-balanced",
      "printSafety": {
        "required": true,
        "rules": [
          "The main conclusion should remain readable in the browser and on the first printed page.",
          "Section boundaries, heading hierarchy, chart captions, and footer/meta content must survive print or PDF export.",
          "Do not rely on motion, hover, sticky-only layouts, or screen-only decoration to make the structure understandable."
        ]
      },
      "allowedComponents": [
        "eyebrow",
        "title_block",
        "summary_strip",
        "body_paragraph",
        "fact_card",
        "quote_block",
        "divider_section",
        "footer_meta",
        "kpi_card",
        "chart_frame",
        "legend",
        "insight_callout",
        "method_note",
        "table_block",
        "table_of_contents",
        "section_anchor",
        "step_rail"
      ],
      "allowedPatterns": [
        "hero",
        "section_stack",
        "faq",
        "card_list",
        "chapter_divider",
        "evidence_break",
        "quote_break",
        "kpi_row",
        "trend_section",
        "distribution_section",
        "anomaly_section",
        "source_footer"
      ],
      "allowedCharts": [
        "bar",
        "line",
        "area",
        "scatter",
        "table",
        "timeline",
        "matrix",
        "donut",
        "candlestick",
        "waterfall"
      ],
      "rules": [
        "Treat web output as a document surface, not a dashboard canvas.",
        "Alternate dense and calm sections on long pages.",
        "Use motion only for entrance or section transitions, never for comprehension."
      ],
