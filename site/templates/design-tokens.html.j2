<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ meta.title }}</title>
  <style>
    :root {
      --ink: #172033;
      --ink-subtle: #4C566A;
      --paper: #FAF8F4;
      --canvas: #F2EFE8;
      --line: #D8D2C4;
      --brand: #244C7A;
      --brand-muted: #DCE7F2;
      --accent: #B65C3A;
      --accent-muted: #F2E1D9;
      --success: #2F6B4F;
      --success-muted: #D9F2E5;
      --warning: #A46A21;
      --warning-muted: #F0EBD9;
      --danger: #9A3D3D;
      --danger-muted: #F2D9D9;
      --font-serif: "Noto Serif SC", "Source Han Serif SC", "Songti SC", serif;
      --font-sans: "Inter", "Noto Sans SC", "PingFang SC", sans-serif;
      --font-mono: "IBM Plex Mono", "SFMono-Regular", monospace;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: var(--font-sans);
      font-size: 15px;
      line-height: 1.6;
      color: var(--ink);
      background: var(--paper);
      -webkit-font-smoothing: antialiased;
    }

    .page {
      max-width: 1152px;
      margin: 0 auto;
      padding: 80px 48px;
    }

    /* Header */
    .page-header {
      margin-bottom: 64px;
      padding-bottom: 40px;
      border-bottom: 1.5px solid var(--line);
    }
    .page-header .eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.04em;
      color: var(--ink-subtle);
      margin-bottom: 20px;
    }
    .page-header h1 {
      font-family: var(--font-serif);
      font-size: 44px;
      font-weight: 600;
      line-height: 1.15;
      color: var(--ink);
      margin-bottom: 16px;
    }
    .page-header .subtitle {
      font-size: 18px;
      color: var(--ink-subtle);
      max-width: 640px;
      line-height: 1.5;
    }

    /* Section titles */
    h2 {
      font-family: var(--font-serif);
      font-size: 26px;
      font-weight: 600;
      color: var(--ink);
      margin-bottom: 10px;
    }
    .section-intro {
      font-size: 15px;
      color: var(--ink-subtle);
      margin-bottom: 32px;
      line-height: 1.55;
    }
    section {
      margin-bottom: 72px;
    }

    /* Color swatches */
    .color-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 16px;
    }
    .color-swatch {
      border-radius: 10px;
      overflow: hidden;
      border: 1px solid var(--line);
    }
    .swatch-block {
      height: 80px;
    }
    .swatch-info {
      padding: 12px 14px;
      background: var(--paper);
    }
    .swatch-info .name {
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 500;
      color: var(--ink);
      margin-bottom: 4px;
    }
    .swatch-info .hex {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--ink-subtle);
    }

    /* Typography */
    .type-sample {
      margin-bottom: 36px;
    }
    .type-sample .label {
      font-family: var(--font-mono);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--ink-subtle);
      margin-bottom: 10px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--line);
    }
    .type-sample.serif .preview { font-family: var(--font-serif); }
    .type-sample.sans .preview { font-family: var(--font-sans); }
    .type-sample.mono .preview { font-family: var(--font-mono); }
    .type-sample .preview-lg {
      font-size: 32px;
      font-weight: 600;
      margin-bottom: 8px;
      color: var(--ink);
    }
    .type-sample .preview-md {
      font-size: 18px;
      margin-bottom: 6px;
      color: var(--ink);
    }
    .type-sample .preview-sm {
      font-size: 13px;
      color: var(--ink-subtle);
      line-height: 1.55;
    }
    .type-sample .css-var {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--brand);
      margin-top: 8px;
    }

    /* Spacing */
    .space-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 16px;
    }
    .space-item {
      padding: 20px 22px;
      background: var(--canvas);
      border-radius: 8px;
      border: 1px solid var(--line);
    }
    .space-item .token-name {
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 500;
      color: var(--ink);
      margin-bottom: 6px;
    }
    .space-item .token-value {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--ink-subtle);
      margin-bottom: 8px;
    }
    .space-bar {
      height: 6px;
      background: var(--brand);
      border-radius: 3px;
    }

    /* Philosophy */
    .philosophy-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px;
    }
    .phil-card {
      padding: 28px;
      background: var(--canvas);
      border-radius: 10px;
      border: 1px solid var(--line);
    }
    .phil-card h3 {
      font-family: var(--font-serif);
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 10px;
      color: var(--ink);
    }
    .phil-card p {
      font-size: 14px;
      color: var(--ink-subtle);
      line-height: 1.55;
    }

    /* Code blocks */
    .code-block {
      margin-top: 24px;
      margin-bottom: 24px;
      background: var(--canvas);
      border: 1px solid var(--line);
      border-radius: 8px;
      overflow: hidden;
    }
    .code-block .code-label {
      padding: 8px 16px;
      font-family: var(--font-mono);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--ink-subtle);
      border-bottom: 1px solid var(--line);
      background: rgba(0,0,0,0.03);
    }
    .code-block pre {
      margin: 0;
      padding: 20px 24px;
      overflow-x: auto;
      font-family: var(--font-mono);
      font-size: 13px;
      line-height: 1.6;
      color: var(--ink);
      white-space: pre;
    }
    .code-block code {
      font-family: var(--font-mono);
      font-size: 13px;
    }

    @media (max-width: 700px) {
      .page { padding: 48px 24px; }
      .page-header h1 { font-size: 32px; }
      .color-grid { grid-template-columns: repeat(2, 1fr); }
      .philosophy-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="page">
    <header class="page-header">
      <p class="eyebrow">{{ meta.eyebrow }}</p>
      <h1>{{ meta.title }}</h1>
      <p class="subtitle">{{ meta.subtitle }}</p>
    </header>

    {% if intro %}
    <section>
      <p class="section-intro">{{ intro }}</p>
    </section>
    {% endif %}

    <section>
      <h2>{{ colors.title }}</h2>
      <p class="section-intro">{{ colors.description }}</p>
      <div class="color-grid">
        {% for c in colors.swatches %}
        <div class="color-swatch">
          <div class="swatch-block" style="background: {{ c.hex }};"></div>
          <div class="swatch-info">
            <div class="name">{{ c.name }}</div>
            <div class="hex">{{ c.hex }}{% if c.var %} &middot; {{ c.var }}{% endif %}</div>
          </div>
        </div>
        {% endfor %}
      </div>
      {% if colors.code_snippet %}
      <div class="code-block">
        <div class="code-label">CSS</div>
        <pre><code>{{ colors.code_snippet }}</code></pre>
      </div>
      {% endif %}
    </section>

    <section>
      <h2>{{ typography.title }}</h2>
      <p class="section-intro">{{ typography.description }}</p>
      {% for t in typography.samples %}
      <div class="type-sample {{ t.class }}">
        <div class="label">{{ t.label }}</div>
        <div class="preview preview-lg">{{ t.headline }}</div>
        <div class="preview preview-md">{{ t.body }}</div>
        <div class="preview preview-sm">{{ t.caption }}</div>
        <div class="css-var">{{ t.css_var }}</div>
      </div>
      {% endfor %}
      {% if typography.code_snippet %}
      <div class="code-block">
        <div class="code-label">CSS</div>
        <pre><code>{{ typography.code_snippet }}</code></pre>
      </div>
      {% endif %}
    </section>

    <section>
      <h2>{{ spacing.title }}</h2>
      <p class="section-intro">{{ spacing.description }}</p>
      <div class="space-grid">
        {% for s in spacing.tokens %}
        <div class="space-item">
          <div class="token-name">{{ s.name }}</div>
          <div class="token-value">{{ s.value }}</div>
          <div class="space-bar" style="width: {{ s.bar_width }}%;"></div>
        </div>
        {% endfor %}
      </div>
      {% if spacing.code_snippet %}
      <div class="code-block">
        <div class="code-label">CSS</div>
        <pre><code>{{ spacing.code_snippet }}</code></pre>
      </div>
      {% endif %}
    </section>

    <section>
      <h2>{{ philosophy.title }}</h2>
      <p class="section-intro">{{ philosophy.description }}</p>
      <div class="philosophy-grid">
        {% for p in philosophy.principles %}
        <div class="phil-card">
          <h3>{{ p.title }}</h3>
          <p>{{ p.body }}</p>
        </div>
        {% endfor %}
      </div>
    </section>
  </div>
</body>
</html>
