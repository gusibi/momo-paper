<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ meta.title }}</title>
  <style>
    /* ===== Design Tokens (shared with engine) ===== */
    :root {
      --ink: #172033;
      --ink-subtle: #4C566A;
      --paper: #FAF8F4;
      --canvas: #F2EFE8;
      --line: #D8D2C4;
      --brand: #244C7A;
      --brand-muted: #DCE7F2;
      --accent: #B65C3A;
      --accent-muted: #F2E1D9;
      --success: #2F6B4F;
      --success-muted: #D9F2E5;
      --warning: #A46A21;
      --font-serif: "Noto Serif SC", "Source Han Serif SC", "Songti SC", serif;
      --font-sans: "Inter", "Noto Sans SC", "PingFang SC", sans-serif;
      --font-mono: "IBM Plex Mono", "SFMono-Regular", monospace;
      --radius-sm: 6px;
      --radius-md: 10px;
      --radius-lg: 16px;
      --shadow-card: 0 1px 3px rgba(23,32,51,0.06), 0 4px 12px rgba(23,32,51,0.04);
      --shadow-raised: 0 4px 8px rgba(23,32,51,0.06), 0 12px 28px rgba(23,32,51,0.08);
      --ease: cubic-bezier(0.22, 0.61, 0.36, 1);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font-sans);
      font-size: 15px;
      line-height: 1.6;
      color: var(--ink);
      background: var(--paper);
      -webkit-font-smoothing: antialiased;
    }

    /* ===== Hero ===== */
    .hero {
      padding: 100px 48px 80px;
      text-align: center;
      background: linear-gradient(180deg, var(--canvas) 0%, var(--paper) 100%);
      border-bottom: 1px solid var(--line);
    }
    .hero-badge {
      display: inline-block;
      padding: 6px 16px;
      background: var(--brand-muted);
      color: var(--brand);
      border-radius: 20px;
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.03em;
      margin-bottom: 32px;
    }
    .hero h1 {
      font-family: var(--font-serif);
      font-size: 52px;
      font-weight: 600;
      line-height: 1.15;
      color: var(--ink);
      max-width: 800px;
      margin: 0 auto 24px;
      letter-spacing: -0.01em;
    }
    .hero .subtitle {
      font-size: 18px;
      line-height: 1.6;
      color: var(--ink-subtle);
      max-width: 620px;
      margin: 0 auto 40px;
    }
    .hero-actions {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      padding: 13px 28px;
      background: var(--brand);
      color: #fff;
      font-family: var(--font-sans);
      font-size: 15px;
      font-weight: 500;
      border-radius: var(--radius-sm);
      text-decoration: none;
      transition: background 0.15s ease, transform 0.15s ease;
    }
    .btn-primary:hover { background: #1a3a5e; transform: translateY(-1px); }
    .btn-outline {
      display: inline-flex;
      align-items: center;
      padding: 13px 28px;
      background: transparent;
      color: var(--brand);
      font-family: var(--font-sans);
      font-size: 15px;
      font-weight: 500;
      border: 1.5px solid var(--brand);
      border-radius: var(--radius-sm);
      text-decoration: none;
      transition: background 0.15s ease, transform 0.15s ease;
    }
    .btn-outline:hover { background: var(--brand-muted); transform: translateY(-1px); }

    /* ===== Features ===== */
    .features {
      max-width: 1152px;
      margin: 0 auto;
      padding: 80px 48px;
    }
    .features-header {
      text-align: center;
      margin-bottom: 56px;
    }
    .features-header h2 {
      font-family: var(--font-serif);
      font-size: 32px;
      font-weight: 600;
      color: var(--ink);
      margin-bottom: 16px;
    }
    .features-header p {
      font-size: 16px;
      color: var(--ink-subtle);
      max-width: 560px;
      margin: 0 auto;
    }
    .feature-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .feature-card {
      padding: 36px 32px;
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .feature-card:hover {
      border-color: var(--brand-muted);
      box-shadow: var(--shadow-raised);
    }
    .feature-icon {
      width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--radius-sm);
      font-size: 20px;
      margin-bottom: 20px;
    }
    .feature-icon.docs    { background: var(--brand-muted); color: var(--brand); }
    .feature-icon.charts  { background: var(--accent-muted); color: var(--accent); }
    .feature-icon.diagrams { background: var(--success-muted); color: var(--success); }
    .feature-icon.templates { background: #F0EBD9; color: var(--warning); }
    .feature-icon.mcp     { background: #E5DFF2; color: #5E3D8A; }
    .feature-icon.print   { background: #D9E8F2; color: #3D6D8A; }
    .feature-card h3 {
      font-family: var(--font-serif);
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 10px;
      color: var(--ink);
    }
    .feature-card p {
      font-size: 14px;
      color: var(--ink-subtle);
      line-height: 1.55;
    }

    /* ===== Numbers Strip ===== */
    .numbers-strip {
      max-width: 1152px;
      margin: 0 auto;
      padding: 0 48px 80px;
    }
    .numbers-inner {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
      padding: 44px 48px;
      background: var(--canvas);
      border-radius: var(--radius-lg);
      border: 1px solid var(--line);
      text-align: center;
    }
    .num-value {
      font-family: var(--font-serif);
      font-size: 40px;
      font-weight: 600;
      color: var(--brand);
      line-height: 1.1;
      margin-bottom: 6px;
    }
    .num-label {
      font-size: 13px;
      color: var(--ink-subtle);
      font-family: var(--font-mono);
      letter-spacing: 0.03em;
    }

    /* ===== Bottom CTA ===== */
    .bottom-cta {
      max-width: 1152px;
      margin: 0 auto;
      padding: 0 48px 100px;
    }
    .cta-inner {
      text-align: center;
      padding: 64px 48px;
      background: linear-gradient(135deg, var(--brand) 0%, #1a3a5e 100%);
      border-radius: var(--radius-lg);
      color: #fff;
    }
    .cta-inner h2 {
      font-family: var(--font-serif);
      font-size: 32px;
      font-weight: 600;
      margin-bottom: 14px;
    }
    .cta-inner p {
      font-size: 16px;
      opacity: 0.85;
      max-width: 500px;
      margin: 0 auto 32px;
      line-height: 1.55;
    }
    .cta-inner .btn-primary {
      background: #fff;
      color: var(--brand);
      font-weight: 600;
    }
    .cta-inner .btn-primary:hover { background: var(--brand-muted); }

    /* ===== Responsive ===== */
    @media (max-width: 860px) {
      .hero { padding: 64px 24px 56px; }
      .hero h1 { font-size: 36px; }
      .hero .subtitle { font-size: 16px; }
      .feature-grid { grid-template-columns: 1fr; }
      .numbers-inner { grid-template-columns: repeat(2, 1fr); row-gap: 32px; }
      .features { padding: 56px 24px; }
      .features-header h2 { font-size: 28px; }
      .bottom-cta { padding: 0 24px 72px; }
      .cta-inner { padding: 44px 28px; }
    }

    @media (max-width: 500px) {
      .hero h1 { font-size: 28px; }
      .numbers-inner { grid-template-columns: 1fr; }
      .hero-actions { flex-direction: column; align-items: center; }
    }
  </style>
</head>
<body>
  {% macro render_hero() %}
  <section class="hero">
    {% if hero.badge %}<div class="hero-badge">{{ hero.badge }}</div>{% endif %}
    <h1>{{ hero.headline }}</h1>
    <p class="subtitle">{{ hero.description }}</p>
    <div class="hero-actions">
      {% for btn in hero.cta_buttons %}
      <a href="{{ btn.url }}" class="{{ btn.style | default('btn-primary') }}">{{ btn.label }}</a>
      {% endfor %}
    </div>
  </section>
  {% endmacro %}

  {% macro render_features() %}
  <section class="features">
    <div class="features-header">
      <h2>{{ features.heading }}</h2>
      <p>{{ features.description }}</p>
    </div>
    <div class="feature-grid">
      {% for feat in features.cards %}
      <div class="feature-card">
        <div class="feature-icon {{ feat.icon_class }}">{{ feat.icon }}</div>
        <h3>{{ feat.title }}</h3>
        <p>{{ feat.description }}</p>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endmacro %}

  {% macro render_numbers() %}
  <section class="numbers-strip">
    <div class="numbers-inner">
      {% for n in numbers %}
      <div>
        <div class="num-value">{{ n.value }}</div>
        <div class="num-label">{{ n.label }}</div>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endmacro %}

  {% macro render_bottom_cta() %}
  <section class="bottom-cta">
    <div class="cta-inner">
      <h2>{{ bottom_cta.heading }}</h2>
      <p>{{ bottom_cta.description }}</p>
      <a href="{{ bottom_cta.button_url }}" class="btn-primary">{{ bottom_cta.button_label }}</a>
    </div>
  </section>
  {% endmacro %}

  {{ render_hero() }}
  {{ render_features() }}
  {{ render_numbers() }}
  {{ render_bottom_cta() }}
</body>
</html>
